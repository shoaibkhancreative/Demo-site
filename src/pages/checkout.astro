---
import Base from "../layouts/Base.astro";
import { CHAPTERS, TOTAL_CLASSES, PRICING, ADDONS, TELEGRAM } from "../data/site.js";
---
<Base title="Checkout · Exclusive Mentorship">
  <section class="mx-auto max-w-3xl px-6 py-16">
    <div class="reveal text-center">
      <p class="eyebrow">Checkout</p>
      <h1 class="mt-2 text-4xl font-semibold sm:text-5xl">Get your access.</h1>
      <p class="mt-3 muted">Choose the bundle, or pick chapters one by one.</p>
    </div>

    <div class="mt-12 grid gap-6 md:grid-cols-[1fr_360px] md:items-start">
      <!-- LEFT -->
      <div class="space-y-4">
        <!-- Plan toggle -->
        <div class="surface p-1.5">
          <div class="grid grid-cols-2 gap-1.5" data-plan-toggle>
            <button type="button" class="rounded-lg px-4 py-2.5 text-sm font-medium transition data-[active=true]:bg-[color:var(--color-ink)] data-[active=true]:text-white" data-plan="bundle" data-active="true">Full bundle</button>
            <button type="button" class="rounded-lg px-4 py-2.5 text-sm font-medium transition data-[active=true]:bg-[color:var(--color-ink)] data-[active=true]:text-white" data-plan="chapters" data-active="false">Chapter by chapter</button>
          </div>
        </div>

        <!-- BUNDLE view -->
        <div class="surface p-6" data-view="bundle">
          <div class="flex items-start justify-between">
            <div>
              <p class="eyebrow">Full bundle · recommended</p>
              <h2 class="mt-1 text-lg font-semibold">Everything, unlocked.</h2>
            </div>
            <span class="chip">Save ${PRICING.save}</span>
          </div>
          <ul class="mt-4 space-y-2 text-[13px] muted">
            <li>✓ All {TOTAL_CLASSES} scripted classes across 7 chapters</li>
            <li>✓ Main private channel access</li>
            <li>✓ 7-day money-back guarantee</li>
            <li>✓ Lifetime access to updates</li>
          </ul>
        </div>

        <!-- CHAPTERS view -->
        <div class="surface hidden p-6" data-view="chapters">
          <div class="flex items-center justify-between">
            <h2 class="text-lg font-semibold">Select chapters</h2>
            <button type="button" class="text-xs font-medium text-[color:var(--color-accent)]" data-select-all>Select all (${PRICING.tier1Total})</button>
          </div>
          <p class="mt-1 text-xs muted">Buying every chapter separately totals <span class="font-semibold text-[color:var(--color-ink)]">${PRICING.tier1Total}</span> — the bundle saves you ${PRICING.save}.</p>
          <div class="mt-4 space-y-1.5">
            {CHAPTERS.map((c) => (
              <label class="flex cursor-pointer items-center justify-between rounded-lg border px-3.5 py-2.5 text-sm transition hover:border-[color:var(--color-accent)]">
                <span class="flex items-center gap-3">
                  <input type="checkbox" data-chapter value={c.price} class="h-4 w-4 accent-[color:var(--color-accent)]" />
                  <span>{String(c.id).padStart(2,'0')} · {c.name} <span class="faint">({c.classes})</span></span>
                </span>
                <span class="font-semibold text-[color:var(--color-accent)]">${c.price}</span>
              </label>
            ))}
          </div>
        </div>

        <!-- Add-ons (data-driven) -->
        <div class="space-y-2.5">
          <p class="px-1 text-xs font-medium muted">Add-ons</p>
          {ADDONS.map((a) => (
            <label class="surface flex cursor-pointer items-start justify-between gap-4 p-5"
                   data-addon-item data-id={a.id} data-price={a.price} data-free-bundle={a.freeWithBundle ? "1" : "0"}>
              <span class="flex items-start gap-3">
                <input type="checkbox" data-addon-check class="mt-0.5 h-4 w-4 accent-[color:var(--color-accent)]" checked={a.freeWithBundle} disabled={a.freeWithBundle} />
                <span>
                  <span class="flex items-center gap-2 text-sm font-medium">
                    {a.name}
                    {a.badge && <span class="chip !py-0.5 !px-2 !border-[color:var(--color-accent)] !text-[color:var(--color-accent)]">{a.badge}</span>}
                  </span>
                  <span class="mt-0.5 block text-[13px] muted" data-addon-note>{a.desc}</span>
                </span>
              </span>
              <span class="whitespace-nowrap text-sm font-semibold" data-addon-tag>{a.freeWithBundle ? "Free" : `+$${a.price}`}</span>
            </label>
          ))}
        </div>
      </div>

      <!-- RIGHT: summary -->
      <div class="surface sticky top-20 p-6">
        <p class="eyebrow">Order summary</p>
        <div class="mt-4 space-y-2.5 text-sm">
          <div class="flex justify-between"><span class="muted" data-sum-label>Full bundle</span><span class="font-medium" data-sum-base>${PRICING.tier2Bundle}</span></div>
          <div data-sum-addons class="space-y-2.5"></div>
          <div class="my-3 rule"></div>
          <div class="flex justify-between text-base"><span class="font-semibold">Total</span><span class="font-semibold" data-sum-total>${PRICING.tier2Bundle}</span></div>
        </div>
        <p class="mt-3 text-[12px] faint" data-sum-hint>You save ${PRICING.save} vs buying every chapter.</p>
        <a href="/signup" class="btn btn-accent mt-5 w-full">Continue to payment</a>
        <div class="mt-4 flex items-center justify-center gap-2 text-[11px] faint">
          <span class="chip !py-0.5 !px-2">₿ BTC</span><span class="chip !py-0.5 !px-2">₮ USDT</span><span class="chip !py-0.5 !px-2">Ξ ETH</span>
        </div>
        <p class="mt-3 text-center text-[12px] muted">New to crypto? <a href={TELEGRAM} class="text-[color:var(--color-accent)]">Telegram support →</a></p>
      </div>
    </div>

    <!-- Payment methods + support (compact, effective) -->
    <div class="reveal mt-8 grid gap-3 sm:grid-cols-[1fr_auto] sm:items-center surface p-5">
      <div class="flex flex-wrap items-center gap-x-6 gap-y-2">
        <span class="text-[13px] font-medium">Pay securely with crypto</span>
        <div class="flex items-center gap-4 text-[13px] muted">
          <span>₿ Bitcoin</span><span>₮ USDT</span><span>Ξ Ethereum</span>
        </div>
      </div>
      <p class="text-[12px] muted sm:text-right">New to crypto? <a href={TELEGRAM} class="font-medium text-[color:var(--color-accent)]">Request support on Telegram →</a></p>
    </div>
  </section>

  <script is:inline define:vars={{ BUNDLE: PRICING.tier2Bundle, TIER1: PRICING.tier1Total, SAVE: PRICING.save }}>
    (function(){
      const bind = () => {
        const $ = (s) => document.querySelector(s);
        const $$ = (s) => Array.from(document.querySelectorAll(s));
        if (!$('[data-plan-toggle]')) return;

        let plan = 'bundle';
        const money = (n) => (n === 0 ? 'Free' : '$' + n);
        const chapters = () => $$('[data-chapter]');
        const addonItems = () => $$('[data-addon-item]');

        const els = {
          toggle: $$('[data-plan-toggle] [data-plan]'),
          viewBundle: $('[data-view="bundle"]'),
          viewChapters: $('[data-view="chapters"]'),
          sumLabel: $('[data-sum-label]'),
          sumBase: $('[data-sum-base]'),
          sumAddons: $('[data-sum-addons]'),
          sumTotal: $('[data-sum-total]'),
          sumHint: $('[data-sum-hint]'),
          selectAll: $('[data-select-all]'),
        };

        function render(){
          let base = 0;
          if (plan === 'bundle') {
            base = BUNDLE;
            els.sumLabel.textContent = 'Full bundle';
            els.sumHint.textContent = 'You save $' + SAVE + ' vs buying every chapter.';
          } else {
            base = chapters().filter(c=>c.checked).reduce((s,c)=>s+Number(c.value),0);
            const count = chapters().filter(c=>c.checked).length;
            els.sumLabel.textContent = count ? (count + (count>1?' chapters':' chapter')) : 'No chapters selected';
            els.sumHint.textContent = 'All 7 chapters separately = $' + TIER1 + '. Bundle is $' + BUNDLE + '.';
          }

          let addonsCost = 0;
          const lines = [];
          addonItems().forEach(item => {
            const price = Number(item.getAttribute('data-price'));
            const freeBundle = item.getAttribute('data-free-bundle') === '1';
            const check = item.querySelector('[data-addon-check]');
            const note = item.querySelector('[data-addon-note]');
            const tag = item.querySelector('[data-addon-tag]');
            const name = item.querySelector('.text-sm.font-medium').childNodes[0].textContent.trim();

            let included = false, cost = 0, tagText = '+$' + price;

            if (freeBundle && plan === 'bundle') {
              check.checked = true; check.disabled = true;
              included = true; cost = 0; tagText = 'Free';
            } else {
              check.disabled = false;
              included = check.checked;
              cost = included ? price : 0;
              tagText = '+$' + price;
            }
            tag.textContent = tagText;

            // summary line
            if (freeBundle && plan === 'bundle') {
              lines.push('<div class="flex justify-between"><span class="muted">'+name+'</span><span class="font-medium">Free</span></div>');
            } else if (included) {
              lines.push('<div class="flex justify-between"><span class="muted">'+name+'</span><span class="font-medium">$'+price+'</span></div>');
            }
            addonsCost += cost;
          });

          els.sumAddons.innerHTML = lines.join('');
          els.sumBase.textContent = money(base);
          els.sumTotal.textContent = money(base + addonsCost);
        }

        els.toggle.forEach(btn=>{
          btn.addEventListener('click', ()=>{
            plan = btn.getAttribute('data-plan');
            els.toggle.forEach(b=> b.setAttribute('data-active', String(b===btn)));
            els.viewBundle.classList.toggle('hidden', plan!=='bundle');
            els.viewChapters.classList.toggle('hidden', plan!=='chapters');
            render();
          });
        });
        chapters().forEach(c=> c.addEventListener('change', render));
        addonItems().forEach(item => item.querySelector('[data-addon-check]').addEventListener('change', render));
        if (els.selectAll) els.selectAll.addEventListener('click', ()=>{ chapters().forEach(c=>c.checked=true); render(); });

        render();
      };
      document.addEventListener('DOMContentLoaded', bind);
      document.addEventListener('astro:page-load', bind);
    })();
  </script>
</Base>
