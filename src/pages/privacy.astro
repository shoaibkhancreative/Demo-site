---
import Base from "../layouts/Base.astro";
---
<Base title="Privacy Policy · Exclusive Mentorship">
  <section class="mx-auto max-w-3xl px-6 py-20 text-neutral-300">
    <h1 class="text-3xl font-bold text-white">Privacy Policy</h1>
    <div class="mt-6 space-y-4 text-sm leading-relaxed">
      <p>We collect only the data required to provide access to the mentorship: your name, email, and purchase records. We do not sell your data.</p>
      <p>Account authentication uses a secure session token. Payment is processed by our third-party crypto payment provider; we do not store payment credentials.</p>
      <p>Access delivery is handled via a private Telegram channel. Your Telegram identifier may be used to grant or revoke access based on your purchase status.</p>
      <p>You may request deletion of your account and associated data at any time via Telegram support.</p>
    </div>
  </section>
</Base>
