---
import Base from "../layouts/Base.astro";
---
<Base title="Privacy Policy · Exclusive Mentorship">
  <section class="mx-auto max-w-2xl px-6 py-16">
    <h1 class="text-3xl font-semibold">Privacy Policy</h1>
    <div class="mt-5 space-y-4 text-sm leading-relaxed muted">
      <p>We collect only the data required to provide access: your name, email, and purchase records. We do not sell your data.</p>
      <p>Authentication uses a secure session token. Payment is processed by our third-party crypto provider; we do not store payment credentials.</p>
      <p>Access delivery is via a private Telegram channel. Your Telegram identifier may be used to grant or revoke access based on purchase status.</p>
      <p>You may request deletion of your account at any time via Telegram support.</p>
    </div>
  </section>
</Base>
