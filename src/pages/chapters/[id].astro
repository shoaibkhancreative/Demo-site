---
import Base from "../../layouts/Base.astro";
import Thumb from "../../components/Thumb.astro";
import { CHAPTERS, PRICING, TOTAL_CLASSES, CHAPTER_BUNDLE_PRICING } from "../../data/site.js";
export function getStaticPaths() {
  return CHAPTERS.map((c) => ({ params: { id: String(c.id) }, props: { chapter: c } }));
}
const { chapter } = Astro.props;
const unlockPrice = CHAPTER_BUNDLE_PRICING[chapter.id];
const joinLabel = chapter.id > 1 ? `চ্যাপ্টার 1–${chapter.id} আনলক করুন · $${unlockPrice}` : `চ্যাপ্টার 1 নিন · $${unlockPrice}`;
---
<Base title={`${chapter.name} · Exclusive Mentorship`}>
  <section class="mx-auto max-w-2xl px-6 py-16">
    <a href="/#curriculum" class="text-sm muted transition hover:text-ivory">← কারিকুলামে ফিরে যান</a>
    <div class="reveal mt-6 relative">
      <Thumb src={chapter.thumb} label={`চ্যাপ্টার ${chapter.id}`} id={chapter.id} />
      <span class="chip-gold chip absolute right-3 top-3">${unlockPrice}</span>
    </div>
    <p class="reveal mt-6 eyebrow">চ্যাপ্টার {chapter.id} · {chapter.classes}টি ক্লাস</p>
    <h1 class="reveal mt-3 text-3xl text-ivory sm:text-4xl">{chapter.name}</h1>
    <p class="reveal mt-3 text-[15px] leading-relaxed muted">{chapter.hook}</p>
    <div class="reveal mt-6 flex flex-wrap items-center gap-3">
      <a href={`/checkout?chapter=${chapter.id}`} class="btn btn-accent">{joinLabel}</a>
      <a href="/checkout" class="text-sm font-medium text-gold transition hover:opacity-75">অথবা বান্ডেলে সবগুলো {TOTAL_CLASSES}টি নিন →</a>
    </div>
    {chapter.id > 1 && <p class="reveal mt-2 text-[12px] faint">চ্যাপ্টারগুলো একটার উপর আরেকটা নির্ভর করে তৈরি, তাই এটি একসাথে চ্যাপ্টার 1 থেকে {chapter.id} পর্যন্ত আনলক করে দেয়।</p>}

    <ol class="mt-10 space-y-3">
      {chapter.lessons.map((l) => (
        <li class="reveal surface hoverable p-5 sm:p-6">
          <div class="flex items-start gap-4">
            <span class="grid h-9 w-9 shrink-0 place-items-center rounded-lg border border-gold-dim/40 bg-gold/[.06] font-display text-[14px] text-gold">{String(l.n).padStart(2,'0')}</span>
            <div class="min-w-0 flex-1">
              <p class="text-[15.5px] font-semibold leading-snug text-ivory">{l.title}</p>
              <p class="mt-1 text-[13px] font-medium italic text-gold">{l.tagline}</p>
              <p class="mt-3 text-[13.5px] leading-relaxed muted">{l.desc}</p>
            </div>
          </div>
        </li>
      ))}
    </ol>

    <div class="reveal surface mt-12 p-7 text-center">
      <p class="text-lg font-semibold text-ivory">সবগুলো {TOTAL_CLASSES}টি ক্লাস নিন।</p>
      <p class="mt-1.5 text-sm muted">ফুল বান্ডেলের মাধ্যমে প্রতিটা চ্যাপ্টার আনলক করুন এবং ${PRICING.save} সাশ্রয় করুন।</p>
      <a href="/checkout" class="btn btn-accent mt-5">ফুল বান্ডেল নিন · ${PRICING.tier2Bundle}</a>
    </div>
  </section>
</Base>
