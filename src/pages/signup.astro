---
import Base from "../layouts/Base.astro";
---
<Base title="Sign Up · Exclusive Mentorship">
  <section class="mx-auto flex max-w-md flex-col px-6 py-24">
    <h1 class="display text-3xl">Create your account</h1>
    <p class="mt-2 text-sm muted">Sign up to purchase and access your classes.</p>
    <form class="mt-8 space-y-3" onsubmit="event.preventDefault()">
      <input type="text" placeholder="Full name" required class="w-full rounded-xl border bg-white px-4 py-3 text-sm outline-none focus:border-[color:var(--color-gold)]" />
      <input type="email" placeholder="Email" required class="w-full rounded-xl border bg-white px-4 py-3 text-sm outline-none focus:border-[color:var(--color-gold)]" />
      <input type="password" placeholder="Password" required class="w-full rounded-xl border bg-white px-4 py-3 text-sm outline-none focus:border-[color:var(--color-gold)]" />
      <button class="btn btn-primary w-full">Create account</button>
    </form>
    <p class="mt-6 text-center text-sm muted">Already a member? <a href="/login" class="text-[color:var(--color-gold)]">Log in</a></p>
  </section>
</Base>
