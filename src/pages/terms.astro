---
import Base from "../layouts/Base.astro";
---
<Base title="Terms of Service · Exclusive Mentorship">
  <section class="mx-auto max-w-3xl px-6 py-20">
    <h1 class="display text-4xl">Terms of Service</h1>
    <div class="mt-6 space-y-4 text-sm leading-relaxed muted">
      <p>All content is for educational purposes only and does not constitute financial, investment, or trading advice.</p>
      <p>Access is licensed to a single member. Sharing, redistributing, or reselling any class, invite link, or material is strictly prohibited and results in immediate termination without refund.</p>
      <p>Trading involves substantial risk. You are solely responsible for your own decisions and outcomes.</p>
      <p>We reserve the right to revoke access for any violation of these terms.</p>
    </div>
  </section>
</Base>
