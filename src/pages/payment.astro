---
import Base from "../layouts/Base.astro";
import { CHAPTERS, ADDONS, TELEGRAM, TELEGRAM_BOT, PAYMENT_METHODS, ADDON_CODES, CHAPTER_BUNDLE_PRICING } from "../data/site.js";
---
<Base title="পেমেন্ট · Exclusive Mentorship">
  <section class="mx-auto max-w-2xl px-6 py-16">
    <div class="reveal text-center">
      <p class="eyebrow">পেমেন্ট</p>
      <h1 class="mt-2 text-4xl font-semibold sm:text-5xl">আপনার পেমেন্ট পাঠান।</h1>
      <p class="mt-3 muted">নিচে ক্রিপ্টো দিয়ে পেমেন্ট করুন, তারপর কনফার্ম করে অ্যাক্সেস নিন।</p>
    </div>

    <!-- Order summary -->
    <div class="reveal surface mt-10 p-6" data-order-summary>
      <p class="eyebrow">আপনার অর্ডার</p>
      <div class="mt-3 space-y-2 text-sm" data-order-lines>
        <p class="muted">আপনার অর্ডার লোড হচ্ছে…</p>
      </div>
      <div class="my-3 rule"></div>
      <div class="flex justify-between text-base">
        <span class="font-semibold">মোট পেমেন্ট</span>
        <span class="font-semibold" data-order-total>—</span>
      </div>
    </div>

    <!-- Shown only if someone lands here with no order in the URL -->
    <div class="reveal surface mt-4 hidden p-6 text-center" data-no-order>
      <p class="text-sm muted">আমরা কোনো অর্ডার খুঁজে পাইনি। আগে চেকআউটে ফিরে গিয়ে একটি প্ল্যান বেছে নিন।</p>
      <a href="/checkout" class="btn btn-accent mt-4">চেকআউটে ফিরে যান</a>
    </div>

    <div data-payment-block>
      <!-- Payment methods -->
      <div class="reveal surface mt-4 p-6">
        <p class="eyebrow">ক্রিপ্টো দিয়ে পেমেন্ট করুন</p>
        <p class="mt-1 text-[13px] muted">উপরের সঠিক মোট পরিমাণ নিচের যেকোনো একটি মাধ্যমে পাঠান। পাঠানোর আগে UID অথবা address আরেকবার ভালো করে চেক করে নিন — ক্রিপ্টো পেমেন্ট একবার পাঠালে আর ফেরত বা বাতিল করা যায় না।</p>

        <div class="mt-5 space-y-2.5">
          <div class="flex items-center justify-between gap-3 rounded-lg border px-4 py-3">
            <div class="min-w-0">
              <p class="text-xs font-medium muted">Binance UID</p>
              <p class="truncate font-mono text-sm">{PAYMENT_METHODS.binanceUID}</p>
            </div>
            <button type="button" class="btn btn-ghost btn-sm shrink-0" data-copy={PAYMENT_METHODS.binanceUID}>কপি করুন</button>
          </div>

          <div class="flex items-center justify-between gap-3 rounded-lg border px-4 py-3">
            <div class="min-w-0">
              <p class="text-xs font-medium muted">Bybit UID</p>
              <p class="truncate font-mono text-sm">{PAYMENT_METHODS.bybitUID}</p>
            </div>
            <button type="button" class="btn btn-ghost btn-sm shrink-0" data-copy={PAYMENT_METHODS.bybitUID}>কপি করুন</button>
          </div>

          {PAYMENT_METHODS.crypto.map((c) => (
            <div class="flex items-center justify-between gap-3 rounded-lg border px-4 py-3">
              <div class="min-w-0">
                <p class="text-xs font-medium muted">{c.label} · {c.network}</p>
                <p class="truncate font-mono text-sm">{c.address}</p>
              </div>
              <button type="button" class="btn btn-ghost btn-sm shrink-0" data-copy={c.address}>কপি করুন</button>
            </div>
          ))}
        </div>
      </div>

      <!-- Confirm -> Share screenshot on Telegram -->
      <div class="reveal surface mt-4 p-6 text-center">
        <div data-step-confirm>
          <p class="text-sm font-medium">পেমেন্ট ইতিমধ্যে পাঠিয়েছেন?</p>
          <p class="mt-1 text-[13px] muted">কনফার্ম-এ ট্যাপ করুন, তারপর একটি screenshot শেয়ার করবেন যাতে আমরা তা ভেরিফাই করতে পারি।</p>
          <button type="button" id="confirmBtn" class="btn btn-accent mt-4">পেমেন্ট কনফার্ম করুন</button>
        </div>
        <div data-step-share class="hidden">
          <p class="text-sm font-medium">শেষ একটি ধাপ</p>
          <p class="mt-1 text-[13px] muted">নিচে ট্যাপ করে Telegram খুলুন, তারপর যে চ্যাটটি খুলবে সেখানে আপনার পেমেন্টের screenshot পাঠান। সেখান থেকেই আমরা আপনার অ্যাক্সেস কনফার্ম করে দেব।</p>
          <a id="shareBtn" href="#" target="_blank" rel="noopener" class="btn btn-accent mt-4">Telegram-এ screenshot শেয়ার করুন</a>
          <p class="mt-4 text-[11px] faint">Telegram খোলেনি? সরাসরি <span id="botHandle" class="font-medium"></span>-কে মেসেজ করে এই অর্ডার কোডটি পেস্ট করুন:</p>
          <div class="mt-2 flex items-center justify-center gap-2">
            <code class="rounded-md border px-2.5 py-1 text-[12px]" id="orderCode">—</code>
            <button type="button" class="btn btn-ghost btn-sm" data-copy-code>কপি করুন</button>
          </div>
        </div>
      </div>
    </div>

    <p class="reveal mt-6 text-center text-[12px] muted">সাহায্য দরকার? <a href={TELEGRAM} class="text-[color:var(--color-accent)]">Telegram-এ মেসেজ করুন →</a></p>
  </section>

  <script is:inline define:vars={{ CHAPTERS, ADDONS, ADDON_CODES, TELEGRAM_BOT, CHAPTER_BUNDLE_PRICING }}>
    (function () {
      const bind = () => {
        const $ = (s) => document.querySelector(s);
        if (!$('[data-order-summary]')) return;

        const params = new URLSearchParams(location.search);
        const plan = params.get('plan');
        const count = Number(params.get('count')) || 0;
        const addons = (params.get('addons') || '').split(',').filter(Boolean);
        const total = Number(params.get('total'));

        if (!plan || !total) {
          $('[data-order-summary]').classList.add('hidden');
          $('[data-payment-block]').classList.add('hidden');
          $('[data-no-order]').classList.remove('hidden');
          return;
        }

        // Build human-readable order lines from the query params.
        const lines = [];
        if (plan === 'bundle') {
          lines.push(['ফুল বান্ডেল', null]);
        } else if (count > 0) {
          const lastName = CHAPTERS.find((c) => c.id === count)?.name;
          lines.push([`চ্যাপ্টার 1–${count}${lastName ? ` ("${lastName}" পর্যন্ত)` : ''}`, '$' + CHAPTER_BUNDLE_PRICING[count]]);
        } else {
          lines.push(['কোনো চ্যাপ্টার বেছে নেওয়া হয়নি', null]);
        }
        addons.forEach((id) => {
          const a = ADDONS.find((x) => x.id === id);
          if (a) lines.push([a.name, null]);
        });

        $('[data-order-lines]').innerHTML = lines
          .map(([name, price]) => `<div class="flex justify-between"><span class="muted">${name}</span>${price ? `<span class="font-medium">${price}</span>` : ''}</div>`)
          .join('');
        $('[data-order-total]').textContent = '$' + total;

        // Compact Telegram deep-link payload: PLAN-ITEMS-ADDONS-TOTAL
        // Telegram's ?start= value allows only A-Z a-z 0-9 _ - and max 64 characters.
        // ITEMS is "0" for the bundle, or the chapter count N for chapters mode (always
        // means chapters 1..N, since chapters can only be bought in sequential order).
        const planChar = plan === 'bundle' ? 'B' : 'C';
        const itemsPart = plan === 'bundle' ? '0' : String(count || 0);
        const addonsPart = addons.map((id) => ADDON_CODES[id] || '').join('') || '0';
        const code = `${planChar}-${itemsPart}-${addonsPart}-${Math.round(total)}`;

        $('#orderCode').textContent = code;
        $('#botHandle').textContent = '@' + TELEGRAM_BOT;
        $('#shareBtn').href = `https://t.me/${TELEGRAM_BOT}?start=${code}`;

        // Copy-to-clipboard for UID/address rows and the fallback order code.
        const copy = async (text, btn) => {
          try {
            await navigator.clipboard.writeText(text);
            const old = btn.textContent;
            btn.textContent = 'কপি হয়েছে';
            setTimeout(() => (btn.textContent = old), 1500);
          } catch (e) {
            /* clipboard unavailable — the value is still visible to select manually */
          }
        };
        document.querySelectorAll('[data-copy]').forEach((btn) => {
          btn.addEventListener('click', () => copy(btn.getAttribute('data-copy'), btn));
        });
        const copyCodeBtn = $('[data-copy-code]');
        if (copyCodeBtn) copyCodeBtn.addEventListener('click', () => copy(code, copyCodeBtn));

        // Step 1 "Confirm payment" -> reveals step 2 "Share screenshot on Telegram"
        const confirmBtn = $('#confirmBtn');
        if (confirmBtn) {
          confirmBtn.addEventListener('click', () => {
            $('[data-step-confirm]').classList.add('hidden');
            $('[data-step-share]').classList.remove('hidden');
          });
        }
      };
      document.addEventListener('DOMContentLoaded', bind);
      document.addEventListener('astro:page-load', bind);
    })();
  </script>
</Base>
