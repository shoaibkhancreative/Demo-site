---
import Base from "../layouts/Base.astro";
import { CHAPTERS } from "../data/site.js";
---
<Base title="ড্যাশবোর্ড · Exclusive Mentorship">
  <section class="mx-auto max-w-4xl px-6 py-16">
    <p class="eyebrow">সদস্য এলাকা</p>
    <h1 class="mt-3 text-2xl text-ivory">আপনার ড্যাশবোর্ড</h1>
    <p class="mt-1.5 text-sm muted">আপনার অ্যাক্সেস আর কেনাকাটার ইতিহাস ম্যানেজ করুন।</p>
    <h2 class="mt-10 text-sm font-semibold text-ivory">আপনার চ্যাপ্টার</h2>
    <div class="mt-3 grid gap-2.5 md:grid-cols-2">
      {CHAPTERS.map((c) => (
        <div class="surface flex items-center justify-between p-3.5">
          <div><p class="text-sm font-medium text-ivory">{c.name}</p><p class="text-xs muted">{c.classes}টি ক্লাস</p></div>
          <span class="chip">লকড</span>
        </div>
      ))}
    </div>
    <h2 class="mt-10 text-sm font-semibold text-ivory">কেনাকাটার ইতিহাস</h2>
    <div class="surface mt-3 p-5 text-sm muted">এখনো কোনো কেনাকাটা হয়নি।</div>
  </section>
</Base>
