---
import Base from "../layouts/Base.astro";
import { CHAPTERS } from "../data/site.js";
---
<Base title="Dashboard · Exclusive Mentorship">
  <section class="mx-auto max-w-5xl px-6 py-20">
    <h1 class="display text-3xl">Your dashboard</h1>
    <p class="mt-2 text-sm muted">Manage your access and purchase history.</p>
    <h2 class="mt-12 text-lg font-semibold">Your chapters</h2>
    <div class="mt-4 grid gap-3 md:grid-cols-2">
      {CHAPTERS.map((c) => (
        <div class="surface flex items-center justify-between p-4">
          <div><p class="text-sm font-medium">{c.name}</p><p class="text-xs muted">{c.classes} classes</p></div>
          <span class="rounded-full border px-3 py-1 text-xs muted">Locked</span>
        </div>
      ))}
    </div>
    <h2 class="mt-12 text-lg font-semibold">Purchase history</h2>
    <div class="surface mt-4 p-6 text-sm muted">No purchases yet.</div>
  </section>
</Base>
