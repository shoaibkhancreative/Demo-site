---
import Base from "../layouts/Base.astro";
import { CHAPTERS } from "../data/site.js";
---
<Base title="Dashboard · Exclusive Mentorship">
  <section class="mx-auto max-w-4xl px-6 py-16">
    <h1 class="text-2xl font-semibold">Your dashboard</h1>
    <p class="mt-1.5 text-sm muted">Manage your access and purchase history.</p>
    <h2 class="mt-10 text-sm font-semibold">Your chapters</h2>
    <div class="mt-3 grid gap-2.5 md:grid-cols-2">
      {CHAPTERS.map((c) => (
        <div class="surface flex items-center justify-between p-4">
          <div><p class="text-sm font-medium">{c.name}</p><p class="text-xs muted">{c.classes} classes</p></div>
          <span class="chip">Locked</span>
        </div>
      ))}
    </div>
    <h2 class="mt-10 text-sm font-semibold">Purchase history</h2>
    <div class="surface mt-3 p-5 text-sm muted">No purchases yet.</div>
  </section>
</Base>
