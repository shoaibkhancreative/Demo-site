---
import Base from "../layouts/Base.astro";
import Journey from "../components/Journey.astro";
import {
  TOTAL_CLASSES, PRICING, TESTIMONIALS, INSTRUCTOR, YOUTUBE_ID,
  CHAPTERS, ADDONS, CHAPTER_BUNDLE_PRICING,
} from "../data/site.js";

// Chapter-by-chapter step chart — real numbers straight from CHAPTER_BUNDLE_PRICING,
// scaled to fit, so if the pricing curve ever changes this chart changes with it.
const chapterPrices = Object.entries(CHAPTER_BUNDLE_PRICING).map(([id, price]) => ({ id: Number(id), price }));
const maxPrice = Math.max(...chapterPrices.map((c) => c.price));
const BAR_W = 30, GAP = 11, BASELINE = 98, MAX_H = 80;
const bars = chapterPrices.map((c, i) => {
  const h = Math.max(5, Math.round((c.price / maxPrice) * MAX_H));
  return { ...c, x: 8 + i * (BAR_W + GAP), h, y: BASELINE - h };
});
const stepChartWidth = 8 + chapterPrices.length * (BAR_W + GAP) + 8;
---
<Base>
  <!-- ============================================================ HERO -->
  <section class="wrap mx-auto max-w-2xl px-6 pb-8 pt-16 text-center sm:pt-24">
    <span class="reveal eyebrow mx-auto w-fit">{CHAPTERS.length} চ্যাপ্টার · {TOTAL_CLASSES} ক্লাস · ১টি ফ্রেমওয়ার্ক</span>
    <h1 class="reveal mt-6 text-[2.5rem] font-semibold leading-[1.15] sm:text-[3.35rem]">
      মার্কেট এলোমেলো নয়।<br />
      এটা একটা <span class="relative inline-block whitespace-nowrap text-[color:var(--color-gold-deep)]">ভাষা
        <svg class="absolute -bottom-2 left-0 w-full" viewBox="0 0 200 12" preserveAspectRatio="none" aria-hidden="true"><path d="M2 9C40 2 160 2 198 9" stroke="var(--color-gold)" stroke-width="4" fill="none" stroke-linecap="round" /></svg>
      </span>।
    </h1>
    <p class="reveal mx-auto mt-6 max-w-lg text-[16.5px] leading-relaxed muted">
      {CHAPTERS.length}টি চ্যাপ্টারে সাজানো {TOTAL_CLASSES}টি scripted ক্লাস — institutional ফ্রেমওয়ার্ক, প্রফেশনাল mindset আর একটা লিখিত trading plan মিলে তৈরি হয় একটাই পরিষ্কার পথ।
    </p>
    <div class="reveal mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row">
      <a href="/checkout" class="btn btn-gold">সম্পূর্ণ অ্যাক্সেস নিন · ${PRICING.tier2Bundle}</a>
      <a href="#intro" class="btn btn-ghost">পরিচিতি ভিডিও দেখুন ▸</a>
    </div>
  </section>

  <!-- ============================================================ HERO CHART (signature element) -->
  <section class="wrap mx-auto max-w-4xl px-4 pb-12 sm:px-6">
    <div class="reveal chart-stage p-4 sm:p-8">
      <svg viewBox="0 0 640 380" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="একটি অ্যানোটেটেড মার্কেট স্ট্রাকচার চার্ট — liquidity sweep থেকে break of structure পর্যন্ত">
        <text x="14" y="26" font-family="var(--font-mono)" font-size="11.5" letter-spacing="1" fill="var(--color-ink-faint)">XAUUSD · H4</text>
        <text x="626" y="26" text-anchor="end" font-family="var(--font-mono)" font-size="11.5" letter-spacing="1" fill="var(--color-ink-faint)">SMART MONEY MODEL</text>

        <g stroke-linecap="round">
          <line x1="40" y1="256" x2="40" y2="277" stroke="var(--color-ink)" stroke-width="1.6" opacity=".55" />
          <rect x="32" y="261" width="16" height="9" rx="2" fill="var(--color-ink)" opacity=".88" />
          <line x1="78" y1="257" x2="78" y2="281" stroke="var(--color-ink)" stroke-width="1.6" opacity=".55" />
          <rect x="70" y="261" width="16" height="13" rx="2" fill="none" stroke="var(--color-ink)" stroke-width="1.6" />
          <line x1="116" y1="253" x2="116" y2="282" stroke="var(--color-ink)" stroke-width="1.6" opacity=".55" />
          <rect x="108" y="259" width="16" height="15" rx="2" fill="var(--color-ink)" opacity=".88" />
          <line x1="154" y1="254" x2="154" y2="287" stroke="var(--color-ink)" stroke-width="1.6" opacity=".55" />
          <rect x="146" y="259" width="16" height="18" rx="2" fill="none" stroke="var(--color-ink)" stroke-width="1.6" />
          <line x1="192" y1="258" x2="192" y2="283" stroke="var(--color-ink)" stroke-width="1.6" opacity=".55" />
          <rect x="184" y="263" width="16" height="14" rx="2" fill="var(--color-ink)" opacity=".88" />
          <line x1="230" y1="259" x2="230" y2="287" stroke="var(--color-ink)" stroke-width="1.6" opacity=".55" />
          <rect x="222" y="263" width="16" height="16" rx="2" fill="none" stroke="var(--color-ink)" stroke-width="1.6" />
          <line x1="268" y1="261" x2="268" y2="281" stroke="var(--color-ink)" stroke-width="1.6" opacity=".55" />
          <rect x="260" y="266" width="16" height="13" rx="2" fill="var(--color-ink)" opacity=".88" />
          <line x1="306" y1="261" x2="306" y2="316" stroke="var(--color-ink)" stroke-width="1.6" opacity=".55" />
          <rect x="298" y="266" width="16" height="6" rx="2" fill="none" stroke="var(--color-ink)" stroke-width="1.6" />
          <line x1="344" y1="262" x2="344" y2="277" stroke="var(--color-ink)" stroke-width="1.6" opacity=".55" />
          <rect x="336" y="266" width="16" height="5" rx="2" fill="none" stroke="var(--color-ink)" stroke-width="1.6" />
          <line x1="382" y1="222" x2="382" y2="273" stroke="var(--color-ink)" stroke-width="1.6" opacity=".55" />
          <rect x="374" y="228" width="16" height="43" rx="2" fill="var(--color-ink)" opacity=".92" />
          <line x1="420" y1="197" x2="420" y2="231" stroke="var(--color-ink)" stroke-width="1.6" opacity=".55" />
          <rect x="412" y="203" width="16" height="25" rx="2" fill="var(--color-ink)" opacity=".92" />
          <line x1="458" y1="199" x2="458" y2="220" stroke="var(--color-ink)" stroke-width="1.6" opacity=".55" />
          <rect x="450" y="203" width="16" height="10" rx="2" fill="none" stroke="var(--color-ink)" stroke-width="1.6" />
          <line x1="496" y1="174" x2="496" y2="216" stroke="var(--color-ink)" stroke-width="1.6" opacity=".55" />
          <rect x="488" y="179" width="16" height="34" rx="2" fill="var(--color-ink)" opacity=".92" />
          <line x1="534" y1="144" x2="534" y2="182" stroke="var(--color-ink)" stroke-width="1.6" opacity=".55" />
          <rect x="526" y="149" width="16" height="30" rx="2" fill="var(--color-ink)" opacity=".92" />
          <line x1="572" y1="106" x2="572" y2="152" stroke="var(--color-ink)" stroke-width="1.6" opacity=".55" />
          <rect x="564" y="112" width="16" height="37" rx="2" fill="var(--color-ink)" opacity=".92" />
        </g>

        <g>
          <line x1="95" y1="287" x2="345" y2="287" stroke="var(--color-gold)" stroke-width="1.6" stroke-dasharray="5 5" class="chart-fade" style="animation-delay:.5s" />
          <text x="97" y="303" font-family="var(--font-mono)" font-size="14" fill="var(--color-ink-soft)" class="chart-fade" style="animation-delay:.75s">Sell-Side Liquidity</text>

          <circle cx="306" cy="316" r="4.5" fill="var(--color-gold)" class="chart-pop" style="animation-delay:1.15s" />
          <line x1="309" y1="312" x2="332" y2="297" stroke="var(--color-gold)" stroke-width="1.4" class="chart-draw" style="animation-delay:1.3s" />
          <text x="336" y="300" font-family="var(--font-mono)" font-size="14" fill="var(--color-ink-soft)" class="chart-fade" style="animation-delay:1.65s">Liquidity Sweep</text>

          <rect x="330" y="259" width="28" height="23" rx="3" fill="var(--color-gold)" fill-opacity=".14" stroke="var(--color-gold)" stroke-width="1.2" stroke-dasharray="3 3" class="chart-fade" style="animation-delay:2s" />
          <text x="366" y="274" font-family="var(--font-mono)" font-size="14" fill="var(--color-ink-soft)" class="chart-fade" style="animation-delay:2.2s">Order Block</text>

          <line x1="25" y1="248" x2="400" y2="248" stroke="var(--color-gold)" stroke-width="1.6" stroke-dasharray="5 5" class="chart-fade" style="animation-delay:2.5s" />
          <text x="203" y="237" font-family="var(--font-mono)" font-size="14" fill="var(--color-ink-soft)" class="chart-fade" style="animation-delay:2.75s">BOS · Break of Structure</text>
        </g>
      </svg>
    </div>
    <div class="reveal mt-5 flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-[12px] muted">
      <span>✓ ফুল বান্ডেলে ৭ দিনের মানি-ব্যাক গ্যারান্টি</span>
      <span>✓ Telegram-এ সরাসরি ডেলিভারি</span>
      <span>✓ ক্রিপ্টোতে পেমেন্ট</span>
    </div>
  </section>

  <!-- ============================================================ INTRO VIDEO -->
  <section id="intro" class="mx-auto max-w-3xl px-6 pb-20">
    <p class="reveal eyebrow mx-auto mb-5 w-fit">৩ মিনিটের পরিচিতি</p>
    <div class="reveal video-frame">
      <iframe src={`https://www.youtube-nocookie.com/embed/${YOUTUBE_ID}`} title="পরিচিতি" loading="lazy" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
    </div>
  </section>

  <!-- ============================================================ CURRICULUM -->
  <section id="curriculum" class="mx-auto max-w-3xl px-6 pb-20">
    <div class="reveal mb-10 text-center">
      <p class="eyebrow mx-auto w-fit">কারিকুলাম</p>
      <h2 class="mt-3 text-[1.9rem] font-semibold sm:text-4xl">সাতটি ধাপ। একটাই ভিত্তি।</h2>
      <p class="mx-auto mt-3 max-w-md text-sm muted">প্রতিটা চ্যাপ্টার আগেরটার উপর দাঁড়িয়ে তৈরি। যেকোনো ধাপে ক্লিক করে পুরো লেসন লিস্ট দেখুন।</p>
    </div>
    <Journey />
  </section>

  <!-- ============================================================ PRICING -->
  <section id="pricing" class="mx-auto max-w-4xl px-6 pb-20">
    <div class="reveal mb-10 text-center">
      <p class="eyebrow mx-auto w-fit">মূল্য</p>
      <h2 class="mt-3 text-[1.9rem] font-semibold sm:text-4xl">দুইটা পথ। একই গন্তব্য।</h2>
      <p class="mx-auto mt-3 max-w-md text-sm muted">পুরোটা একসাথে নিন, অথবা চ্যাপ্টার ধরে ধরে এগিয়ে যান — দুই পথই আপনাকে একই {TOTAL_CLASSES}টা ক্লাসে পৌঁছে দেবে।</p>
    </div>

    <div class="grid gap-5 sm:grid-cols-2">
      <div class="reveal price-card price-card--featured">
        <span class="chip badge-gold absolute right-6 top-6">সেরা পছন্দ</span>
        <p class="eyebrow">ফুল বান্ডেল</p>
        <div class="mt-3 flex items-end gap-2.5">
          <span class="price-num text-5xl">${PRICING.tier2Bundle}</span>
          <span class="mb-1.5 text-base faint line-through">${PRICING.tier1Total}</span>
        </div>
        <p class="mt-1.5 text-[13px] font-medium text-[color:var(--color-emerald)]">${PRICING.save} সাশ্রয় হচ্ছে</p>
        <ul class="mt-5 space-y-2.5 text-[13.5px] muted">
          <li class="flex gap-2"><span class="text-[color:var(--color-emerald)]">✓</span> সবগুলো {TOTAL_CLASSES}টি scripted ক্লাস</li>
          <li class="flex gap-2"><span class="text-[color:var(--color-emerald)]">✓</span> Priority সাপোর্ট একদম <span class="font-medium text-[color:var(--color-ink)]">ফ্রি</span></li>
          <li class="flex gap-2"><span class="text-[color:var(--color-emerald)]">✓</span> মূল প্রাইভেট চ্যানেলে অ্যাক্সেস</li>
          <li class="flex gap-2"><span class="text-[color:var(--color-emerald)]">✓</span> ৭ দিনের মানি-ব্যাক গ্যারান্টি</li>
          <li class="flex gap-2"><span class="text-[color:var(--color-emerald)]">✓</span> Lifetime আপডেট</li>
        </ul>
        <a href="/checkout" class="btn btn-gold btn-block mt-7">সম্পূর্ণ অ্যাক্সেস নিন</a>
      </div>

      <div class="reveal price-card">
        <p class="eyebrow">চ্যাপ্টার অনুযায়ী</p>
        <div class="mt-3 flex items-end gap-1.5">
          <span class="price-num text-3xl">${CHAPTERS[0].price}</span><span class="mb-1 text-sm faint">থেকে শুরু</span>
        </div>
        <p class="mt-3 text-[13px] leading-relaxed muted">ছোট থেকে শুরু করুন। প্রতিটা নতুন চ্যাপ্টারে আরও বড় ছাড় — সবগুলো {CHAPTERS.length}টা একসাথে নিলে দাম দাঁড়ায় ঠিক ফুল বান্ডেলের সমান।</p>

        <div class="mt-4">
          <svg viewBox={`0 0 ${stepChartWidth} 126`} class="w-full">
            {bars.map((b, i) => (
              <g>
                <rect x={b.x} y={b.y} width={BAR_W} height={b.h} rx="3"
                  fill={i === bars.length - 1 ? "var(--color-gold)" : "var(--color-paper-dim)"}
                  stroke={i === bars.length - 1 ? "none" : "var(--color-line)"} />
                <text x={b.x + BAR_W / 2} y={b.y - 6} text-anchor="middle" font-family="var(--font-mono)" font-size="10.5" fill="var(--color-ink-soft)">${b.price}</text>
                <text x={b.x + BAR_W / 2} y={BASELINE + 14} text-anchor="middle" font-family="var(--font-mono)" font-size="9.5" fill="var(--color-ink-faint)">{String(b.id).padStart(2, '0')}</text>
              </g>
            ))}
          </svg>
        </div>

        <a href="/checkout" class="btn btn-ghost btn-block mt-5">চ্যাপ্টার বেছে নিন</a>
      </div>
    </div>

    <div class="reveal mt-5 grid gap-3.5 sm:grid-cols-3">
      {ADDONS.map((a) => (
        <div class="addon-card">
          <div class="flex items-center justify-between gap-2">
            <span class="font-mono text-base font-bold">${a.price}</span>
            {a.badge ? <span class="chip badge-gold">{a.badge}</span> : a.freeWithBundle ? <span class="chip badge-emerald">বান্ডেলে ফ্রি</span> : null}
          </div>
          <p class="mt-2.5 text-[14px] font-semibold">{a.name}</p>
          <p class="mt-1 text-[12.5px] leading-relaxed muted">{a.desc}</p>
          {a.validity && <p class="mt-2 text-[11px] font-medium text-[color:var(--color-gold-deep)]">মেয়াদ · {a.validity}</p>}
        </div>
      ))}
    </div>
    <p class="reveal mt-3 text-center text-[11.5px] faint">*ফুল বান্ডেল বা ৫+ চ্যাপ্টারে Priority সাপোর্ট ফ্রি।</p>

    <div class="reveal mt-6 flex items-center gap-4 rounded-2xl border border-[color:var(--color-gold)]/[.3] bg-[color:var(--color-gold)]/[.05] px-6 py-5">
      <div class="grid h-11 w-11 shrink-0 place-items-center rounded-full bg-[color:var(--color-gold)]/[.15] text-lg">🛡</div>
      <div>
        <p class="text-sm font-semibold">৭ দিনের মানি-ব্যাক গ্যারান্টি — শুধু ফুল বান্ডেলে</p>
        <p class="text-[13px] muted">ফুল বান্ডেল ঝুঁকিহীনভাবে ব্যবহার করে দেখুন। ৭ দিনের মধ্যে মনে না ধরলে, কোনো ঝামেলা ছাড়াই সম্পূর্ণ রিফান্ড পাবেন। <span class="faint">এই গ্যারান্টি শুধুমাত্র ফুল বান্ডেল প্যাকেজের জন্য প্রযোজ্য — চ্যাপ্টার-বাই-চ্যাপ্টার কেনাকাটা বা যেকোনো অ্যাড-অনের জন্য প্রযোজ্য নয়।</span></p>
      </div>
    </div>
  </section>

  <!-- ============================================================ INSTRUCTOR -->
  <section id="instructor" class="band-navy">
    <div class="wrap mx-auto max-w-4xl px-6 py-20">
      <div class="reveal grid gap-8 sm:grid-cols-[auto_1fr] sm:items-center">
        <div class="flex items-center gap-4 sm:flex-col sm:items-start sm:gap-4 sm:border-r sm:border-[rgba(250,248,243,.14)] sm:pr-10">
          <span class="grid h-16 w-16 place-items-center rounded-2xl bg-[color:var(--color-gold)] font-display text-xl font-bold text-[color:var(--color-navy)]">NLT</span>
          <div>
            <p class="text-[15px] font-semibold leading-tight">{INSTRUCTOR}</p>
            <p class="muted-on-navy text-[12.5px]">ট্রেডার · মেন্টর</p>
          </div>
        </div>
        <div>
          <p class="eyebrow !text-[color:var(--color-gold-bright)]">মেন্টরের বার্তা</p>
          <h2 class="mt-2 text-[1.7rem] font-semibold leading-tight sm:text-[2rem]">ভাগ্য নয় — একটা সিস্টেম।</h2>
          <p class="muted-on-navy mt-4 text-[14.5px] leading-relaxed">বেশিরভাগ ট্রেডার লস করে এই কারণে না যে তারা স্মার্ট না — বরং এই কারণে যে তাদের কেউ কখনো একটা আসল system দেয়নি। এটাই ঠিক সেই framework, mindset আর plan যা আমি নিজে ব্যবহার করি, {TOTAL_CLASSES}টি scripted ক্লাসে সাজিয়ে দেওয়া হয়েছে।</p>
          <div class="mt-6 flex flex-wrap gap-3">
            <a href="/checkout" class="btn btn-gold btn-sm">আপনার journey শুরু করুন · ${PRICING.tier2Bundle}</a>
            <a href="#curriculum" class="btn btn-on-navy btn-sm">কী কী শিখবেন দেখুন</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================ TESTIMONIALS -->
  <section class="pb-6 pt-20">
    <div class="reveal mx-auto mb-10 max-w-3xl px-6 text-center">
      <p class="eyebrow mx-auto w-fit">ফলাফল</p>
      <h2 class="mt-3 text-[1.9rem] font-semibold sm:text-4xl">আসল ট্রেডারদের আস্থা।</h2>
      <p class="mx-auto mt-3 max-w-md text-sm muted">যারা এই পথ অনুসরণ করেছেন, তাদের ট্রেড করার ধরনটাই বদলে গেছে।</p>
    </div>

    <div class="reveal marquee space-y-3">
      <div class="marquee-track left">
        {[...TESTIMONIALS.slice(0, 6), ...TESTIMONIALS.slice(0, 6)].map((t) => (
          <figure class="t-card p-5">
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-2.5">
                <span class="grid h-8 w-8 place-items-center rounded-full bg-[color:var(--color-ink)] text-[11px] font-semibold text-[color:var(--color-gold-bright)]">{t.name.split(" ").map(w => w[0]).join("").slice(0, 2)}</span>
                <span>
                  <span class="block text-[13px] font-semibold leading-tight">{t.name}</span>
                  <span class="block text-[11px] faint">{t.role}</span>
                </span>
              </div>
              <span class="text-[11px] text-[color:var(--color-gold)]">★★★★★</span>
            </div>
            <blockquote class="mt-3 text-[13px] leading-relaxed muted">“{t.text}”</blockquote>
            <p class="chip badge-emerald mt-3 inline-block">{t.result}</p>
          </figure>
        ))}
      </div>

      <div class="marquee-track right">
        {[...TESTIMONIALS.slice(6, 12), ...TESTIMONIALS.slice(6, 12)].map((t) => (
          <figure class="t-card p-5">
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-2.5">
                <span class="grid h-8 w-8 place-items-center rounded-full bg-[color:var(--color-ink)] text-[11px] font-semibold text-[color:var(--color-gold-bright)]">{t.name.split(" ").map(w => w[0]).join("").slice(0, 2)}</span>
                <span>
                  <span class="block text-[13px] font-semibold leading-tight">{t.name}</span>
                  <span class="block text-[11px] faint">{t.role}</span>
                </span>
              </div>
              <span class="text-[11px] text-[color:var(--color-gold)]">★★★★★</span>
            </div>
            <blockquote class="mt-3 text-[13px] leading-relaxed muted">“{t.text}”</blockquote>
            <p class="chip badge-emerald mt-3 inline-block">{t.result}</p>
          </figure>
        ))}
      </div>
    </div>

    <div class="reveal mx-auto mt-8 flex max-w-5xl flex-wrap items-center justify-center gap-x-6 gap-y-2 px-6 text-[12px] muted">
      <span>✓ প্রকৃত সদস্য</span>
      <span>✓ ফুল বান্ডেলে ৭ দিনের মানি-ব্যাক গ্যারান্টি</span>
      <span>✓ ৭ দিনের মানি-ব্যাক গ্যারান্টি</span>
    </div>
  </section>
</Base>
