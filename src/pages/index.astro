---
import Base from "../layouts/Base.astro";
import Journey from "../components/Journey.astro";
import { TOTAL_CLASSES, PRICING, TESTIMONIALS, INSTRUCTOR, TELEGRAM, YOUTUBE_ID, CHAPTERS } from "../data/site.js";
---
<Base>
  <!-- HERO -->
  <section class="mx-auto max-w-3xl px-6 pt-24 pb-14 text-center">
    <span class="reveal chip mx-auto">By {INSTRUCTOR} · {TOTAL_CLASSES} scripted classes</span>
    <h1 class="reveal mt-6 text-[2.7rem] font-semibold leading-[1.05] sm:text-6xl">Trade like the institutions.</h1>
    <p class="reveal mx-auto mt-5 max-w-lg text-[17px] leading-relaxed muted">A complete, step-by-step mentorship. No noise, no filler. Only the framework, mindset, and plan used to trade the markets professionally.</p>
    <div class="reveal mt-8 flex flex-col items-center justify-center gap-2.5 sm:flex-row">
      <a href="/checkout" class="btn btn-accent">Get full access · ${PRICING.tier2Bundle}</a>
      <a href="#intro" class="btn btn-ghost">Watch the intro</a>
    </div>
  </section>

  <!-- INTRO VIDEO -->
  <section id="intro" class="mx-auto max-w-3xl px-6 pb-24">
    <div class="reveal video-frame">
      <iframe src={`https://www.youtube-nocookie.com/embed/${YOUTUBE_ID}`} title="Introduction" loading="lazy" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
    </div>
  </section>

  <!-- CURRICULUM -->
  <section id="curriculum" class="mx-auto max-w-5xl px-6 pb-24">
    <div class="reveal mb-8 text-center">
      <p class="eyebrow">Curriculum</p>
      <h2 class="mt-2 text-3xl font-semibold sm:text-4xl">Seven chapters. One clear path.</h2>
      <p class="mx-auto mt-3 max-w-md text-sm muted">Click any chapter to see all its lessons.</p>
    </div>
    <div class="reveal"><Journey /></div>
  </section>

  <!-- PRICING -->
  <section id="pricing" class="mx-auto max-w-5xl px-6 pb-16">
    <div class="reveal mb-8 text-center">
      <p class="eyebrow">Pricing</p>
      <h2 class="mt-2 text-3xl font-semibold sm:text-4xl">One price. Everything included.</h2>
      <p class="mx-auto mt-3 max-w-md text-sm muted">Buying all 7 chapters separately costs ${PRICING.tier1Total}. The bundle gives you everything for ${PRICING.tier2Bundle}.</p>
    </div>

    <div class="mx-auto grid max-w-3xl gap-4 sm:grid-cols-[1.35fr_1fr]">
      <div class="reveal surface relative overflow-hidden p-7 ring-1 ring-[color:var(--color-accent)]">
        <span class="absolute right-4 top-4 chip !border-[color:var(--color-accent)] !text-[color:var(--color-accent)]">Save ${PRICING.save}</span>
        <p class="eyebrow">Full bundle</p>
        <div class="mt-2 flex items-end gap-2">
          <span class="text-5xl font-semibold">${PRICING.tier2Bundle}</span>
          <span class="mb-1.5 text-sm muted line-through">${PRICING.tier1Total}</span>
        </div>
        <ul class="mt-5 space-y-2 text-[13px] muted">
          <li>✓ All {TOTAL_CLASSES} scripted classes</li>
          <li>✓ Priority support included <span class="font-medium text-[color:var(--color-ink)]">free</span></li>
          <li>✓ Main private channel access</li>
          <li>✓ 7-day money-back guarantee</li>
          <li>✓ Lifetime updates</li>
        </ul>
        <a href="/checkout" class="btn btn-accent mt-6 w-full">Get full access</a>
      </div>

      <div class="reveal surface p-7">
        <p class="eyebrow">Chapter by chapter</p>
        <div class="mt-2 flex items-end gap-1.5">
          <span class="text-3xl font-semibold">${CHAPTERS[0].price}</span><span class="mb-1 text-sm muted">/ starting</span>
        </div>
        <p class="mt-4 text-[13px] muted">Prefer to start small? Buy any chapter individually. All 7 separately total <span class="font-semibold text-[color:var(--color-ink)]">${PRICING.tier1Total}</span>.</p>
        <p class="mt-3 text-[13px] muted">Optional Priority Support add-on: <span class="font-medium text-[color:var(--color-ink)]">+${PRICING.prioritySupport}</span>.</p>
        <a href="/checkout" class="btn btn-ghost mt-6 w-full">Choose chapters</a>
      </div>
    </div>

    <!-- Effective guarantee strip -->
    <div class="reveal mx-auto mt-4 flex max-w-3xl items-center gap-4 rounded-xl border border-[color:var(--color-accent)]/30 bg-[color:var(--color-accent)]/[.04] px-6 py-4">
      <div class="grid h-10 w-10 shrink-0 place-items-center rounded-full bg-[color:var(--color-accent)]/10 text-lg">🛡</div>
      <div>
        <p class="text-sm font-semibold">7-day money-back guarantee</p>
        <p class="text-[13px] muted">Try the full bundle risk-free. Not for you within 7 days? Get a full refund, no hassle.</p>
      </div>
    </div>
  </section>

  <!-- INSTRUCTOR (motivational) -->
  <section id="instructor" class="mx-auto max-w-3xl px-6 py-24">
    <div class="reveal surface overflow-hidden p-8 sm:p-12">
      <div class="text-center">
        <div class="mx-auto grid h-16 w-16 place-items-center rounded-full bg-[color:var(--color-ink)] text-lg font-semibold text-white">NLT</div>
        <p class="mt-5 eyebrow">Your instructor</p>
        <h2 class="mt-2 text-3xl font-semibold sm:text-[2.5rem]">Stop guessing.<br/>Start trading with a plan.</h2>
      </div>
      <div class="mx-auto mt-7 max-w-xl space-y-4 text-center text-[15px] leading-relaxed muted">
        <p>Most traders lose not because they aren't smart, but because they never had a real system. They chase, they hope, they blow accounts, and they blame the market.</p>
        <p><span class="font-medium text-[color:var(--color-ink)]">It doesn't have to be you.</span> This mentorship is the exact framework, mindset, and personal trading plan {INSTRUCTOR} uses, distilled into {TOTAL_CLASSES} scripted classes with nothing left to chance.</p>
        <p>You don't need luck. You need structure, discipline, and a path you can actually follow. That's what's waiting inside.</p>
      </div>
      <div class="mt-8 flex flex-col items-center justify-center gap-2.5 sm:flex-row">
        <a href="/checkout" class="btn btn-accent">Begin your journey · ${PRICING.tier2Bundle}</a>
        <a href="#curriculum" class="btn btn-ghost">See what you'll learn</a>
      </div>
    </div>
  </section>

  <!-- TESTIMONIALS (social proof) -->
  <section class="mx-auto max-w-5xl px-6 pb-24">
    <div class="reveal mb-10 text-center">
      <p class="eyebrow">Results</p>
      <h2 class="mt-2 text-3xl font-semibold sm:text-4xl">Trusted by real traders.</h2>
      <p class="mx-auto mt-3 max-w-md text-sm muted">Members who followed the path and changed how they trade.</p>
    </div>

    {TESTIMONIALS.filter(t => t.featured).map((t) => (
      <figure class="reveal surface mx-auto mb-4 max-w-3xl p-8 sm:p-10">
        <div class="text-[color:var(--color-accent)]">★★★★★</div>
        <blockquote class="mt-4 text-xl font-medium leading-relaxed sm:text-2xl">“{t.text}”</blockquote>
        <figcaption class="mt-6 flex items-center gap-3">
          <span class="grid h-11 w-11 place-items-center rounded-full bg-[color:var(--color-ink)] text-sm font-semibold text-white">{t.name.split(" ").map(w=>w[0]).join("").slice(0,2)}</span>
          <span>
            <span class="block text-sm font-semibold">{t.name}</span>
            <span class="block text-[13px] muted">{t.role} · <span class="text-[color:var(--color-accent)]">{t.result}</span></span>
          </span>
        </figcaption>
      </figure>
    ))}

    <div class="grid gap-3 md:grid-cols-3">
      {TESTIMONIALS.filter(t => !t.featured).map((t) => (
        <figure class="reveal surface hoverable flex flex-col p-6">
          <div class="text-[13px] text-[color:var(--color-accent)]">★★★★★</div>
          <blockquote class="mt-3 flex-1 text-[14px] leading-relaxed">“{t.text}”</blockquote>
          <figcaption class="mt-5 flex items-center gap-2.5">
            <span class="grid h-9 w-9 place-items-center rounded-full bg-[color:var(--color-bg)] text-xs font-semibold text-[color:var(--color-ink)]">{t.name.split(" ").map(w=>w[0]).join("").slice(0,2)}</span>
            <span>
              <span class="block text-[13px] font-semibold">{t.name}</span>
              <span class="block text-[12px] muted">{t.role}</span>
            </span>
          </figcaption>
        </figure>
      ))}
    </div>

    <div class="reveal mt-6 flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-[12px] muted">
      <span>✓ Real members</span>
      <span>✓ Verified on Telegram</span>
      <span>✓ 7-day money-back guarantee</span>
    </div>
  </section>
</Base>
