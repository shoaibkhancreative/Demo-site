---
import Base from "../layouts/Base.astro";
import ChapterCard from "../components/ChapterCard.astro";
import { CHAPTERS, TOTAL_CLASSES, PRICING, TESTIMONIALS, INSTRUCTOR, TELEGRAM, YOUTUBE_ID } from "../data/site.js";
---
<Base>
  <!-- HERO -->
  <section class="relative overflow-hidden">
    <div class="pointer-events-none absolute inset-0 -z-10">
      <div class="absolute left-1/2 top-[-12rem] h-[34rem] w-[34rem] -translate-x-1/2 rounded-full bg-gold/[.07] blur-[130px]"></div>
    </div>
    <div class="mx-auto max-w-3xl px-6 pt-32 pb-16 text-center">
      <span class="reveal inline-block text-xs uppercase tracking-[0.3em] text-gold">By {INSTRUCTOR} · {TOTAL_CLASSES} Scripted Classes</span>
      <h1 class="reveal display mt-8 text-5xl leading-[1.05] sm:text-7xl">Trade like the<br/><span class="italic text-gold">institutions.</span></h1>
      <p class="reveal mx-auto mt-8 max-w-xl text-lg leading-relaxed text-neutral-400">A complete, structured mentorship. No noise, no filler. Only the framework, mindset, and plan used to trade the markets professionally.</p>
      <div class="reveal mt-12 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a href="/pricing" class="rounded-full bg-gold px-8 py-3.5 text-sm font-semibold text-black transition hover:bg-gold-soft">Get Full Access · ${PRICING.tier2Bundle}</a>
        <a href="#intro" class="text-sm font-medium text-neutral-300 transition hover:text-gold">Watch the intro →</a>
      </div>
    </div>
  </section>

  <!-- INTRO VIDEO: what, why, how -->
  <section id="intro" class="mx-auto max-w-4xl px-6 pb-24">
    <div class="reveal mb-8 text-center">
      <p class="text-xs uppercase tracking-[0.3em] text-gold">Watch First</p>
      <h2 class="display mt-4 text-4xl">What this is, why it matters, how it works.</h2>
    </div>
    <div class="reveal video-frame card">
      <iframe src={`https://www.youtube-nocookie.com/embed/${YOUTUBE_ID}`} title="Introduction" loading="lazy" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
    </div>
  </section>

  <div class="mx-auto max-w-5xl px-6"><div class="rule"></div></div>

  <!-- CURRICULUM -->
  <section id="curriculum" class="mx-auto max-w-6xl px-6 py-28">
    <div class="reveal mb-16 text-center">
      <p class="text-xs uppercase tracking-[0.3em] text-gold">The Curriculum</p>
      <h2 class="display mt-4 text-4xl sm:text-5xl">Seven chapters. One complete path.</h2>
    </div>
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {CHAPTERS.map((c) => <ChapterCard chapter={c} />)}
    </div>
  </section>

  <!-- REFUND / TRUST BAND -->
  <section class="mx-auto max-w-5xl px-6 pb-8">
    <div class="reveal card rounded-3xl bg-gradient-to-b from-gold/[.08] to-transparent p-10 text-center">
      <div class="mx-auto mb-5 flex h-14 w-14 items-center justify-center rounded-full border border-gold/60 text-2xl text-gold">🛡</div>
      <h2 class="display text-3xl sm:text-4xl">7-Day Money-Back Guarantee</h2>
      <p class="mx-auto mt-4 max-w-xl text-neutral-400">Get the full bundle risk-free. If it's not for you within 7 days, request a refund and your access is removed, no questions asked in good faith.</p>
      <a href="/refund" class="mt-6 inline-block text-sm font-medium text-gold transition hover:text-gold-soft">Read the refund policy →</a>
    </div>
  </section>

  <div class="mx-auto max-w-5xl px-6 py-14"><div class="rule"></div></div>

  <!-- PRICING PREVIEW -->
  <section class="mx-auto max-w-5xl px-6 pb-28">
    <div class="reveal mb-14 text-center">
      <p class="text-xs uppercase tracking-[0.3em] text-gold">Access</p>
      <h2 class="display mt-4 text-4xl sm:text-5xl">Simple, honest pricing.</h2>
    </div>
    <div class="reveal card relative mx-auto max-w-3xl overflow-hidden rounded-3xl border-gold/50 bg-gradient-to-b from-gold/[.08] to-transparent p-10">
      <div class="flex flex-col items-start justify-between gap-8 sm:flex-row sm:items-center">
        <div>
          <p class="text-xs uppercase tracking-[0.25em] text-gold">Full Bundle · Recommended</p>
          <h3 class="display mt-3 text-3xl">Everything, unlocked.</h3>
          <p class="mt-3 max-w-md text-sm text-neutral-400">All {TOTAL_CLASSES} classes across 7 chapters. Priority Support included free. 7-day refund.</p>
        </div>
        <div class="text-right">
          <p class="text-sm text-neutral-500 line-through">${PRICING.tier1Total}</p>
          <p class="display text-5xl">${PRICING.tier2Bundle}</p>
          <p class="text-xs text-gold">Save ${PRICING.save}</p>
        </div>
      </div>
      <a href="/pricing" class="mt-8 block rounded-full bg-gold py-3.5 text-center text-sm font-semibold text-black transition hover:bg-gold-soft sm:inline-block sm:px-10">Get Full Access</a>
    </div>
    <div class="reveal card mx-auto mt-6 flex max-w-3xl flex-col items-center justify-between gap-4 rounded-2xl bg-ink-2 px-8 py-6 sm:flex-row">
      <div>
        <p class="text-sm font-medium text-neutral-200">Prefer to start small?</p>
        <p class="mt-1 text-sm text-neutral-500">Buy chapter by chapter, from ${CHAPTERS[0].price}. Priority Support optional at checkout.</p>
      </div>
      <a href="/pricing" class="shrink-0 rounded-full border border-line px-6 py-2.5 text-sm font-medium text-neutral-300 transition hover:border-gold hover:text-gold">View chapters →</a>
    </div>
  </section>

  <div class="mx-auto max-w-5xl px-6"><div class="rule"></div></div>

  <!-- INSTRUCTOR -->
  <section id="instructor" class="reveal mx-auto max-w-3xl px-6 py-28 text-center">
    <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full border border-gold/60 text-lg font-semibold text-gold">NLT</div>
    <p class="mt-8 text-xs uppercase tracking-[0.3em] text-gold">Your Instructor</p>
    <h2 class="display mt-4 text-4xl">Taught by {INSTRUCTOR}.</h2>
    <p class="mx-auto mt-6 max-w-xl text-lg leading-relaxed text-neutral-400">Every class is scripted and structured, so nothing is left to chance. The same institutional logic, mindset, and personal trading plan, distilled into a clear step-by-step path.</p>
  </section>

  <div class="mx-auto max-w-5xl px-6"><div class="rule"></div></div>

  <!-- TESTIMONIALS -->
  <section class="mx-auto max-w-5xl px-6 py-28">
    <h2 class="reveal display mb-14 text-center text-4xl">Trusted by traders.</h2>
    <div class="grid gap-6 md:grid-cols-3">
      {TESTIMONIALS.map((t) => (
        <figure class="reveal card rounded-2xl bg-ink-2 p-7">
          <div class="text-sm text-gold">★★★★★</div>
          <blockquote class="mt-4 text-[15px] leading-relaxed text-neutral-300">“{t.text}”</blockquote>
          <figcaption class="mt-5 text-sm text-neutral-500">{t.name}</figcaption>
        </figure>
      ))}
    </div>
  </section>

  <!-- CRYPTO -->
  <section class="reveal mx-auto max-w-3xl px-6 pb-32 text-center">
    <h2 class="display text-4xl">Secure crypto payment.</h2>
    <p class="mt-5 text-neutral-400">Pay with Bitcoin, USDT, or ETH. Instant, private, and secure.</p>
    <div class="mt-7 flex flex-wrap items-center justify-center gap-3 text-sm text-neutral-400">
      <span class="card rounded-full px-4 py-1.5">₿ Bitcoin</span>
      <span class="card rounded-full px-4 py-1.5">₮ USDT</span>
      <span class="card rounded-full px-4 py-1.5">Ξ ETH</span>
    </div>
    <p class="mt-9 text-sm text-neutral-500">New to crypto? We'll walk you through it.</p>
    <a href={TELEGRAM} class="mt-4 inline-block rounded-full border border-gold px-7 py-2.5 text-sm font-semibold text-gold transition hover:bg-gold hover:text-black">Request support on Telegram</a>
  </section>
</Base>
