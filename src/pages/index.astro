---
import Base from "../layouts/Base.astro";
import Section from "../components/Section.astro";
import Journey from "../components/Journey.astro";
import { TOTAL_CLASSES, PRICING, TESTIMONIALS, INSTRUCTOR, TELEGRAM, YOUTUBE_ID, CHAPTERS } from "../data/site.js";
---
<Base>
  <!-- HERO -->
  <section class="mx-auto max-w-3xl px-6 pt-24 pb-16 text-center">
    <span class="reveal chip mx-auto">By {INSTRUCTOR} · {TOTAL_CLASSES} scripted classes</span>
    <h1 class="reveal page-title mt-6">Trade like the institutions.</h1>
    <p class="reveal lead mx-auto mt-5 max-w-lg muted">A complete, step-by-step mentorship. No noise, no filler. Only the framework, mindset, and plan used to trade the markets professionally.</p>
    <div class="reveal mt-8 flex flex-col items-center justify-center gap-2.5 sm:flex-row">
      <a href="/checkout" class="btn btn-accent">Get full access · ${PRICING.tier2Bundle}</a>
      <a href="#intro" class="btn btn-ghost">Watch the intro</a>
    </div>
  </section>

  <!-- INTRO VIDEO -->
  <Section id="intro" width="narrow">
    <div class="reveal video-frame"><iframe src={`https://www.youtube-nocookie.com/embed/${YOUTUBE_ID}`} title="Introduction" loading="lazy" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe></div>
  </Section>

  <!-- CURRICULUM -->
  <Section id="curriculum" eyebrow="Curriculum" title="Seven chapters. One clear path." subtitle="Click any chapter to see all its lessons.">
    <div class="reveal"><Journey /></div>
  </Section>

  <!-- PRICING -->
  <Section id="pricing" eyebrow="Pricing" title="One price. Everything included." subtitle={`Buying all 7 chapters separately costs $${PRICING.tier1Total}. The bundle gives you everything for $${PRICING.tier2Bundle}.`}>
    <div class="mx-auto grid max-w-3xl gap-4 sm:grid-cols-[1.35fr_1fr]">
      <div class="reveal surface card-pad relative overflow-hidden ring-1 ring-[color:var(--color-accent)]">
        <span class="absolute right-4 top-4 chip !border-[color:var(--color-accent)] !text-[color:var(--color-accent)]">Save ${PRICING.save}</span>
        <p class="eyebrow">Full bundle</p>
        <div class="mt-2 flex items-end gap-2"><span class="text-5xl font-semibold">${PRICING.tier2Bundle}</span><span class="mb-1.5 text-sm muted line-through">${PRICING.tier1Total}</span></div>
        <ul class="mt-5 space-y-2 text-[13px] muted">
          <li>✓ All {TOTAL_CLASSES} scripted classes</li>
          <li>✓ Priority support included <span class="font-medium text-[color:var(--color-ink)]">free</span></li>
          <li>✓ Main private channel access</li>
          <li>✓ 7-day money-back guarantee</li>
          <li>✓ Lifetime updates</li>
        </ul>
        <a href="/checkout" class="btn btn-accent mt-6 w-full">Get full access</a>
      </div>
      <div class="reveal surface card-pad">
        <p class="eyebrow">Chapter by chapter</p>
        <div class="mt-2 flex items-end gap-1.5"><span class="text-3xl font-semibold">${CHAPTERS[0].price}</span><span class="mb-1 text-sm muted">/ starting</span></div>
        <p class="mt-4 text-[13px] muted">Prefer to start small? Buy any chapter individually. All 7 separately total <span class="font-semibold text-[color:var(--color-ink)]">${PRICING.tier1Total}</span>.</p>
        <p class="mt-3 text-[13px] muted">Optional Priority Support add-on: <span class="font-medium text-[color:var(--color-ink)]">+${PRICING.prioritySupport}</span>.</p>
        <a href="/checkout" class="btn btn-ghost mt-6 w-full">Choose chapters</a>
      </div>
    </div>
    <div class="reveal mx-auto mt-4 flex max-w-3xl items-center gap-4 rounded-xl border border-[color:var(--color-accent)]/30 bg-[color:var(--color-accent)]/[.04] px-6 py-4">
      <div class="grid h-10 w-10 shrink-0 place-items-center rounded-full bg-[color:var(--color-accent)]/10 text-lg">🛡</div>
      <div>
        <p class="text-sm font-semibold">7-day money-back guarantee</p>
        <p class="text-[13px] muted">Try the full bundle risk-free. Not for you within 7 days? Get a full refund, no hassle.</p>
      </div>
    </div>
  </Section>

  <!-- INSTRUCTOR -->
  <Section id="instructor" width="mid">
    <div class="reveal surface card-pad relative overflow-hidden">
      <div class="pointer-events-none absolute -right-16 -top-16 h-52 w-52 rounded-full bg-[color:var(--color-accent)]/[.06] blur-3xl"></div>
      <div class="relative flex flex-col gap-6 sm:flex-row sm:items-center">
        <div class="flex items-center gap-4 sm:flex-col sm:items-start sm:gap-3 sm:border-r sm:pr-8">
          <span class="grid h-14 w-14 place-items-center rounded-2xl bg-[color:var(--color-ink)] text-lg font-semibold text-white">NLT</span>
          <div><p class="text-sm font-semibold leading-tight">{INSTRUCTOR}</p><p class="text-[12px] muted">Trader · Mentor</p></div>
        </div>
        <div class="sm:flex-1">
          <p class="eyebrow">A note from your instructor</p>
          <h2 class="mt-1.5 text-2xl font-semibold leading-tight sm:text-[1.7rem]">Stop guessing. Start trading with a plan.</h2>
          <p class="mt-3 text-[14px] leading-relaxed muted">Most traders don't lose because they aren't smart, but because no one gave them a real system. This is the exact framework, mindset, and plan I use, distilled into {TOTAL_CLASSES} scripted classes. You don't need luck. You need structure, and I'll walk it with you.</p>
          <div class="mt-5 flex flex-wrap gap-2.5">
            <a href="/checkout" class="btn btn-accent btn-sm">Begin your journey · ${PRICING.tier2Bundle}</a>
            <a href="#curriculum" class="btn btn-ghost btn-sm">See what you'll learn</a>
          </div>
        </div>
      </div>
    </div>
  </Section>

  <!-- TESTIMONIALS -->
  <Section eyebrow="Results" title="Trusted by real traders." subtitle="Members who followed the path and changed how they trade." class="!max-w-none !px-0">
    <div class="reveal marquee space-y-3">
      <div class="marquee-track left">
        {[...TESTIMONIALS.slice(0,6), ...TESTIMONIALS.slice(0,6)].map((t) => (
          <figure class="t-card surface p-5">
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-2.5">
                <span class="grid h-8 w-8 place-items-center rounded-full bg-[color:var(--color-ink)] text-[11px] font-semibold text-white">{t.name.split(" ").map(w=>w[0]).join("").slice(0,2)}</span>
                <span><span class="block text-[13px] font-semibold leading-tight">{t.name}</span><span class="block text-[11px] muted">{t.role}</span></span>
              </div>
              <span class="text-[11px] text-[color:var(--color-accent)]">★★★★★</span>
            </div>
            <blockquote class="mt-3 text-[13px] leading-relaxed muted">“{t.text}”</blockquote>
            <p class="mt-3 inline-block rounded-full bg-[color:var(--color-accent)]/[.08] px-2.5 py-0.5 text-[11px] font-medium text-[color:var(--color-accent)]">{t.result}</p>
          </figure>
        ))}
      </div>
      <div class="marquee-track right">
        {[...TESTIMONIALS.slice(6,12), ...TESTIMONIALS.slice(6,12)].map((t) => (
          <figure class="t-card surface p-5">
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-2.5">
                <span class="grid h-8 w-8 place-items-center rounded-full bg-[color:var(--color-ink)] text-[11px] font-semibold text-white">{t.name.split(" ").map(w=>w[0]).join("").slice(0,2)}</span>
                <span><span class="block text-[13px] font-semibold leading-tight">{t.name}</span><span class="block text-[11px] muted">{t.role}</span></span>
              </div>
              <span class="text-[11px] text-[color:var(--color-accent)]">★★★★★</span>
            </div>
            <blockquote class="mt-3 text-[13px] leading-relaxed muted">“{t.text}”</blockquote>
            <p class="mt-3 inline-block rounded-full bg-[color:var(--color-accent)]/[.08] px-2.5 py-0.5 text-[11px] font-medium text-[color:var(--color-accent)]">{t.result}</p>
          </figure>
        ))}
      </div>
    </div>
    <div class="reveal mt-8 flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-[12px] muted">
      <span>✓ Real members</span><span>✓ Verified on Telegram</span><span>✓ 7-day money-back guarantee</span>
    </div>
  </Section>
</Base>
