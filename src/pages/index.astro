---
import Base from "../layouts/Base.astro";
import Journey from "../components/Journey.astro";
import { TOTAL_CLASSES, PRICING, TESTIMONIALS, INSTRUCTOR, TELEGRAM, YOUTUBE_ID, CHAPTERS } from "../data/site.js";
---
<Base>
  <!-- HERO -->
  <section class="mx-auto max-w-3xl px-6 pt-24 pb-16 text-center">
    <span class="reveal chip mx-auto">NLT-এর {TOTAL_CLASSES}টি scripted ক্লাস</span>
    <h1 class="reveal mt-6 text-[2.7rem] font-semibold leading-[1.05] sm:text-6xl">Institutions-দের মতো ট্রেড করুন।</h1>
    <p class="reveal mx-auto mt-5 max-w-lg text-[17px] leading-relaxed muted">সম্পূর্ণ, ধাপে ধাপে সাজানো একটি মেন্টরশিপ। কোনো noise নেই, কোনো filler নেই। শুধু সেই framework, mindset আর plan, যা দিয়ে মার্কেটে প্রফেশনালি ট্রেড করা হয়।</p>
    <div class="reveal mt-8 flex flex-col items-center justify-center gap-2.5 sm:flex-row">
      <a href="/checkout" class="btn btn-accent">সম্পূর্ণ অ্যাক্সেস নিন · ${PRICING.tier2Bundle}</a>
      <a href="#intro" class="btn btn-ghost">পরিচিতি ভিডিও দেখুন</a>
    </div>
  </section>

  <!-- INTRO VIDEO -->
  <section id="intro" class="mx-auto max-w-3xl px-6 pb-16">
    <div class="reveal video-frame">
      <iframe src={`https://www.youtube-nocookie.com/embed/${YOUTUBE_ID}`} title="পরিচিতি" loading="lazy" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
    </div>
  </section>

  <!-- CURRICULUM -->
  <section id="curriculum" class="mx-auto max-w-5xl px-6 pb-16">
    <div class="reveal mb-8 text-center">
      <p class="eyebrow">কারিকুলাম</p>
      <h2 class="mt-2 text-3xl font-semibold sm:text-4xl">সাতটি চ্যাপ্টার। একটাই পরিষ্কার পথ।</h2>
      <p class="mx-auto mt-3 max-w-md text-sm muted">যেকোনো চ্যাপ্টারে ক্লিক করে সব লেসন দেখুন।</p>
    </div>
    <div class="reveal"><Journey /></div>
  </section>

  <!-- PRICING -->
  <section id="pricing" class="mx-auto max-w-5xl px-6 pb-16">
    <div class="reveal mb-8 text-center">
      <p class="eyebrow">মূল্য</p>
      <h2 class="mt-2 text-3xl font-semibold sm:text-4xl">একটাই মূল্য। সব কিছু অন্তর্ভুক্ত।</h2>
      <p class="mx-auto mt-3 max-w-md text-sm muted">আলাদাভাবে সবগুলো 7 চ্যাপ্টার কিনলে খরচ হবে ${PRICING.tier1Total}। বান্ডেলে সব কিছু পাবেন মাত্র ${PRICING.tier2Bundle}-এ।</p>
    </div>

    <div class="mx-auto grid max-w-3xl gap-4 sm:grid-cols-[1.35fr_1fr]">
      <div class="reveal surface relative overflow-hidden p-7 ring-1 ring-[color:var(--color-accent)]">
        <span class="absolute right-4 top-4 chip !border-[color:var(--color-accent)] !text-[color:var(--color-accent)]">${PRICING.save} সাশ্রয়</span>
        <p class="eyebrow">ফুল বান্ডেল</p>
        <div class="mt-2 flex items-end gap-2">
          <span class="text-5xl font-semibold">${PRICING.tier2Bundle}</span>
          <span class="mb-1.5 text-sm muted line-through">${PRICING.tier1Total}</span>
        </div>
        <ul class="mt-5 space-y-2 text-[13px] muted">
          <li>✓ সবগুলো {TOTAL_CLASSES}টি scripted ক্লাস</li>
          <li>✓ Priority সাপোর্ট একদম <span class="font-medium text-[color:var(--color-ink)]">ফ্রি</span></li>
          <li>✓ মূল প্রাইভেট চ্যানেলে অ্যাক্সেস</li>
          <li>✓ 7 দিনের মানি-ব্যাক গ্যারান্টি</li>
          <li>✓ Lifetime আপডেট</li>
        </ul>
        <a href="/checkout" class="btn btn-accent mt-6 w-full">সম্পূর্ণ অ্যাক্সেস নিন</a>
      </div>

      <div class="reveal surface p-7">
        <p class="eyebrow">চ্যাপ্টার অনুযায়ী</p>
        <div class="mt-2 flex items-end gap-1.5">
          <span class="text-3xl font-semibold">${CHAPTERS[0].price}</span><span class="mb-1 text-sm muted">থেকে শুরু</span>
        </div>
        <p class="mt-4 text-[13px] muted">ছোট থেকে শুরু করতে চান? যেকোনো চ্যাপ্টার আলাদাভাবে কিনুন। সবগুলো 7টা আলাদাভাবে কিনলে মোট <span class="font-semibold text-[color:var(--color-ink)]">${PRICING.tier1Total}</span>।</p>
        <p class="mt-3 text-[13px] muted">ঐচ্ছিক Priority সাপোর্ট অ্যাড-অন: <span class="font-medium text-[color:var(--color-ink)]">+${PRICING.prioritySupport}</span>।</p>
        <a href="/checkout" class="btn btn-ghost mt-6 w-full">চ্যাপ্টার বেছে নিন</a>
      </div>
    </div>

    <!-- Effective guarantee strip -->
    <div class="reveal mx-auto mt-4 flex max-w-3xl items-center gap-4 rounded-xl border border-[color:var(--color-accent)]/30 bg-[color:var(--color-accent)]/[.04] px-6 py-4">
      <div class="grid h-10 w-10 shrink-0 place-items-center rounded-full bg-[color:var(--color-accent)]/10 text-lg">🛡</div>
      <div>
        <p class="text-sm font-semibold">7 দিনের মানি-ব্যাক গ্যারান্টি</p>
        <p class="text-[13px] muted">ফুল বান্ডেল ঝুঁকিহীনভাবে ব্যবহার করে দেখুন। 7 দিনের মধ্যে যদি মনে হয় এটা আপনার জন্য না, তাহলে কোনো ঝামেলা ছাড়াই সম্পূর্ণ রিফান্ড পাবেন।</p>
      </div>
    </div>
  </section>

  <!-- INSTRUCTOR (compact, creative) -->
  <section id="instructor" class="mx-auto max-w-4xl px-6 py-16">
    <div class="reveal surface relative overflow-hidden p-8 sm:p-10">
      <div class="pointer-events-none absolute -right-16 -top-16 h-52 w-52 rounded-full bg-[color:var(--color-accent)]/[.06] blur-3xl"></div>
      <div class="relative flex flex-col gap-6 sm:flex-row sm:items-center">
        <!-- identity -->
        <div class="flex items-center gap-4 sm:flex-col sm:items-start sm:gap-3 sm:border-r sm:pr-8">
          <span class="grid h-14 w-14 place-items-center rounded-2xl bg-[color:var(--color-ink)] text-lg font-semibold text-white">NLT</span>
          <div>
            <p class="text-sm font-semibold leading-tight">{INSTRUCTOR}</p>
            <p class="text-[12px] muted">ট্রেডার · মেন্টর</p>
          </div>
        </div>
        <!-- message -->
        <div class="sm:flex-1">
          <p class="eyebrow">আপনার মেন্টরের পক্ষ থেকে একটি বার্তা</p>
          <h2 class="mt-1.5 text-2xl font-semibold leading-tight sm:text-[1.7rem]">আন্দাজ করা বন্ধ করুন। একটি plan নিয়ে ট্রেড শুরু করুন।</h2>
          <p class="mt-3 text-[14px] leading-relaxed muted">বেশিরভাগ ট্রেডার লস করে এই কারণে না যে তারা স্মার্ট না, বরং এই কারণে যে তাদের কেউ কখনো একটা আসল system দেয়নি। এটাই ঠিক সেই framework, mindset আর plan যা আমি নিজে ব্যবহার করি, {TOTAL_CLASSES}টি scripted ক্লাসে সাজিয়ে দেওয়া হয়েছে। আপনার ভাগ্যের দরকার নেই, দরকার structure — আর সেটা আমি আপনার সাথে থেকেই শেখাবো।</p>
          <div class="mt-5 flex flex-wrap gap-2.5">
            <a href="/checkout" class="btn btn-accent btn-sm">আপনার journey শুরু করুন · ${PRICING.tier2Bundle}</a>
            <a href="#curriculum" class="btn btn-ghost btn-sm">কী কী শিখবেন দেখুন</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- TESTIMONIALS (compact two-row wall) -->
  <section class="pb-16">
    <div class="reveal mx-auto mb-8 max-w-5xl px-6 text-center">
      <p class="eyebrow">ফলাফল</p>
      <h2 class="mt-2 text-3xl font-semibold sm:text-4xl">আসল ট্রেডারদের আস্থা।</h2>
      <p class="mx-auto mt-3 max-w-md text-sm muted">যারা এই পথ অনুসরণ করে তাদের ট্রেড করার ধরন বদলে ফেলেছেন।</p>
    </div>

    <div class="reveal marquee space-y-3">
      <div class="marquee-track left">
        {[...TESTIMONIALS.slice(0,6), ...TESTIMONIALS.slice(0,6)].map((t) => (
          <figure class="t-card surface p-5">
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-2.5">
                <span class="grid h-8 w-8 place-items-center rounded-full bg-[color:var(--color-ink)] text-[11px] font-semibold text-white">{t.name.split(" ").map(w=>w[0]).join("").slice(0,2)}</span>
                <span>
                  <span class="block text-[13px] font-semibold leading-tight">{t.name}</span>
                  <span class="block text-[11px] muted">{t.role}</span>
                </span>
              </div>
              <span class="text-[11px] text-[color:var(--color-accent)]">★★★★★</span>
            </div>
            <blockquote class="mt-3 text-[13px] leading-relaxed muted">“{t.text}”</blockquote>
            <p class="mt-3 inline-block rounded-full bg-[color:var(--color-accent)]/[.08] px-2.5 py-0.5 text-[11px] font-medium text-[color:var(--color-accent)]">{t.result}</p>
          </figure>
        ))}
      </div>

      <div class="marquee-track right">
        {[...TESTIMONIALS.slice(6,12), ...TESTIMONIALS.slice(6,12)].map((t) => (
          <figure class="t-card surface p-5">
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-2.5">
                <span class="grid h-8 w-8 place-items-center rounded-full bg-[color:var(--color-ink)] text-[11px] font-semibold text-white">{t.name.split(" ").map(w=>w[0]).join("").slice(0,2)}</span>
                <span>
                  <span class="block text-[13px] font-semibold leading-tight">{t.name}</span>
                  <span class="block text-[11px] muted">{t.role}</span>
                </span>
              </div>
              <span class="text-[11px] text-[color:var(--color-accent)]">★★★★★</span>
            </div>
            <blockquote class="mt-3 text-[13px] leading-relaxed muted">“{t.text}”</blockquote>
            <p class="mt-3 inline-block rounded-full bg-[color:var(--color-accent)]/[.08] px-2.5 py-0.5 text-[11px] font-medium text-[color:var(--color-accent)]">{t.result}</p>
          </figure>
        ))}
      </div>
    </div>

    <div class="reveal mt-8 flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-[12px] muted">
      <span>✓ প্রকৃত সদস্য</span>
      <span>✓ Telegram-এ ভেরিফায়েড</span>
      <span>✓ 7 দিনের মানি-ব্যাক গ্যারান্টি</span>
    </div>
  </section>
</Base>
