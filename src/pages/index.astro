---
import Base from "../layouts/Base.astro";
import Journey from "../components/Journey.astro";
import { TOTAL_CLASSES, PRICING, TESTIMONIALS, INSTRUCTOR, TELEGRAM, YOUTUBE_ID, CHAPTERS } from "../data/site.js";
---
<Base>
  <!-- HERO -->
  <section class="mx-auto max-w-3xl px-6 pt-24 pb-14 text-center">
    <span class="reveal chip mx-auto">By {INSTRUCTOR} · {TOTAL_CLASSES} scripted classes</span>
    <h1 class="reveal mt-6 text-[2.7rem] font-semibold leading-[1.05] sm:text-6xl">Trade like the institutions.</h1>
    <p class="reveal mx-auto mt-5 max-w-lg text-[17px] leading-relaxed muted">A complete, step-by-step mentorship. No noise, no filler. Only the framework, mindset, and plan used to trade the markets professionally.</p>
    <div class="reveal mt-8 flex flex-col items-center justify-center gap-2.5 sm:flex-row">
      <a href="/checkout" class="btn btn-accent">Get full access · ${PRICING.tier2Bundle}</a>
      <a href="#intro" class="btn btn-ghost">Watch the intro</a>
    </div>
  </section>

  <!-- INTRO VIDEO -->
  <section id="intro" class="mx-auto max-w-3xl px-6 pb-24">
    <div class="reveal video-frame">
      <iframe src={`https://www.youtube-nocookie.com/embed/${YOUTUBE_ID}`} title="Introduction" loading="lazy" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
    </div>
  </section>

  <!-- CURRICULUM -->
  <section id="curriculum" class="mx-auto max-w-5xl px-6 pb-24">
    <div class="reveal mb-8 text-center">
      <p class="eyebrow">Curriculum</p>
      <h2 class="mt-2 text-3xl font-semibold sm:text-4xl">Seven chapters. One clear path.</h2>
      <p class="mx-auto mt-3 max-w-md text-sm muted">Click any chapter to see all its lessons.</p>
    </div>
    <div class="reveal"><Journey /></div>
  </section>

  <!-- PRICING (effective) -->
  <section id="pricing" class="mx-auto max-w-5xl px-6 pb-24">
    <div class="reveal mb-8 text-center">
      <p class="eyebrow">Pricing</p>
      <h2 class="mt-2 text-3xl font-semibold sm:text-4xl">One price. Everything included.</h2>
      <p class="mx-auto mt-3 max-w-md text-sm muted">Buying all 7 chapters separately costs ${PRICING.tier1Total}. The bundle gives you everything for ${PRICING.tier2Bundle}.</p>
    </div>

    <div class="mx-auto grid max-w-3xl gap-4 sm:grid-cols-[1.35fr_1fr]">
      <!-- Bundle (highlight) -->
      <div class="reveal surface relative overflow-hidden p-7 ring-1 ring-[color:var(--color-accent)]">
        <span class="absolute right-4 top-4 chip !border-[color:var(--color-accent)] !text-[color:var(--color-accent)]">Save ${PRICING.save}</span>
        <p class="eyebrow">Full bundle</p>
        <div class="mt-2 flex items-end gap-2">
          <span class="text-5xl font-semibold">${PRICING.tier2Bundle}</span>
          <span class="mb-1.5 text-sm muted line-through">${PRICING.tier1Total}</span>
        </div>
        <ul class="mt-5 space-y-2 text-[13px] muted">
          <li>✓ All {TOTAL_CLASSES} scripted classes</li>
          <li>✓ Priority support included <span class="font-medium text-[color:var(--color-ink)]">free</span></li>
          <li>✓ Main private channel access</li>
          <li>✓ 7-day money-back guarantee</li>
          <li>✓ Lifetime updates</li>
        </ul>
        <a href="/checkout" class="btn btn-accent mt-6 w-full">Get full access</a>
      </div>

      <!-- Chapter by chapter -->
      <div class="reveal surface p-7">
        <p class="eyebrow">Chapter by chapter</p>
        <div class="mt-2 flex items-end gap-1.5">
          <span class="text-3xl font-semibold">${CHAPTERS[0].price}</span><span class="mb-1 text-sm muted">/ starting</span>
        </div>
        <p class="mt-4 text-[13px] muted">Prefer to start small? Buy any chapter individually. All 7 separately total <span class="font-semibold text-[color:var(--color-ink)]">${PRICING.tier1Total}</span>.</p>
        <p class="mt-3 text-[13px] muted">Optional Priority Support add-on: <span class="font-medium text-[color:var(--color-ink)]">+${PRICING.prioritySupport}</span>.</p>
        <a href="/checkout" class="btn btn-ghost mt-6 w-full">Choose chapters</a>
        <p class="mt-4 text-[12px] faint">🛡 7-day money-back guarantee on the bundle.</p>
      </div>
    </div>
  </section>

  <!-- INSTRUCTOR -->
  <section id="instructor" class="reveal mx-auto max-w-xl px-6 pb-24 text-center">
    <div class="mx-auto grid h-14 w-14 place-items-center rounded-full border text-sm font-semibold text-[color:var(--color-accent)]">NLT</div>
    <p class="mt-5 eyebrow">Your instructor</p>
    <h2 class="mt-2 text-3xl font-semibold">Taught by {INSTRUCTOR}.</h2>
    <p class="mx-auto mt-4 max-w-lg text-[15px] leading-relaxed muted">Every class is scripted and structured, so nothing is left to chance. The same institutional logic, mindset, and personal trading plan, distilled into a clear step-by-step path.</p>
  </section>

  <!-- TESTIMONIALS -->
  <section class="mx-auto max-w-5xl px-6 pb-24">
    <h2 class="reveal mb-8 text-center text-3xl font-semibold">Trusted by traders.</h2>
    <div class="grid gap-3 md:grid-cols-3">
      {TESTIMONIALS.map((t) => (
        <figure class="reveal surface hoverable p-5">
          <div class="text-[13px] text-[color:var(--color-accent)]">★★★★★</div>
          <blockquote class="mt-3 text-[14px] leading-relaxed">“{t.text}”</blockquote>
          <figcaption class="mt-4 text-[13px] muted">{t.name}</figcaption>
        </figure>
      ))}
    </div>
  </section>

  <!-- PAYMENT METHOD (effective) -->
  <section class="mx-auto max-w-3xl px-6 pb-8">
    <div class="reveal surface p-8 sm:p-10">
      <div class="text-center">
        <p class="eyebrow">Payment</p>
        <h2 class="mt-2 text-3xl font-semibold">Pay securely with crypto.</h2>
        <p class="mx-auto mt-3 max-w-md text-sm muted">Fast, private, and secure. No cards, no banks. Access is delivered instantly to your private Telegram channel after payment.</p>
      </div>
      <div class="mt-8 grid gap-3 sm:grid-cols-3">
        <div class="rounded-xl border p-4 text-center">
          <div class="text-2xl">₿</div><p class="mt-1.5 text-sm font-medium">Bitcoin</p><p class="text-[12px] faint">BTC</p>
        </div>
        <div class="rounded-xl border p-4 text-center">
          <div class="text-2xl">₮</div><p class="mt-1.5 text-sm font-medium">Tether</p><p class="text-[12px] faint">USDT</p>
        </div>
        <div class="rounded-xl border p-4 text-center">
          <div class="text-2xl">Ξ</div><p class="mt-1.5 text-sm font-medium">Ethereum</p><p class="text-[12px] faint">ETH</p>
        </div>
      </div>
      <div class="mt-8 flex flex-col items-center justify-between gap-3 rounded-xl bg-[color:var(--color-bg)] px-5 py-4 sm:flex-row">
        <p class="text-[13px] muted">New to crypto? We'll guide you through every step.</p>
        <a href={TELEGRAM} class="btn btn-ghost btn-sm shrink-0">Request support on Telegram</a>
      </div>
    </div>
  </section>
</Base>
