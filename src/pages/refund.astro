---
import Base from "../layouts/Base.astro";
import { PRICING } from "../data/site.js";
---
<Base title="Refund Policy · Exclusive Mentorship">
  <section class="mx-auto max-w-3xl px-6 py-20">
    <h1 class="display text-4xl">Refund Policy</h1>
    <div class="mt-6 space-y-4 text-sm leading-relaxed muted">
      <p><span class="text-[color:var(--color-ink)] font-medium">7-Day Refund (Full Bundle only).</span> The ${PRICING.tier2Bundle} full bundle is eligible for a refund within 7 days of purchase, provided the request is made in good faith.</p>
      <p>Individual chapter purchases are non-refundable, as access is granted immediately upon payment.</p>
      <p>Upon an approved refund, your access to all private channels and materials is automatically removed.</p>
      <p>To request a refund, contact us via Telegram support within the eligibility window.</p>
    </div>
  </section>
</Base>
