---
import Base from "../layouts/Base.astro";
import { PRICING } from "../data/site.js";
---
<Base title="Refund Policy · Exclusive Mentorship">
  <section class="mx-auto max-w-2xl px-6 py-16">
    <h1 class="text-3xl font-semibold">Refund Policy</h1>
    <div class="mt-5 space-y-4 text-sm leading-relaxed muted">
      <p><span class="font-medium text-[color:var(--color-ink)]">7-Day Refund (Full Bundle only).</span> The ${PRICING.tier2Bundle} full bundle is eligible for a refund within 7 days of purchase, in good faith.</p>
      <p>Individual chapter purchases are non-refundable, as access is granted immediately.</p>
      <p>Upon an approved refund, access to all private channels and materials is automatically removed.</p>
      <p>To request a refund, contact Telegram support within the eligibility window.</p>
    </div>
  </section>
</Base>
