---
import Base from "../layouts/Base.astro";
import { PRICING } from "../data/site.js";
---
<Base title="Refund Policy · Exclusive Mentorship">
  <section class="mx-auto max-w-3xl px-6 py-20 text-neutral-300">
    <h1 class="text-3xl font-bold text-white">Refund Policy</h1>
    <div class="mt-6 space-y-4 text-sm leading-relaxed">
      <p><strong class="text-white">7-Day Refund (Full Bundle only).</strong> The ${PRICING.tier2Bundle} full bundle is eligible for a refund within 7 days of purchase, provided the request is made in good faith.</p>
      <p>Individual chapter purchases (Tier 1) are non-refundable, as access is granted immediately upon payment.</p>
      <p>Upon an approved refund, your access to all private channels and materials is automatically removed.</p>
      <p>To request a refund, contact us via Telegram support within the eligibility window.</p>
    </div>
  </section>
</Base>
