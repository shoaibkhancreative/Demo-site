---
import Base from "../layouts/Base.astro";
---
<Base title="Log in · Exclusive Mentorship">
  <section class="mx-auto flex max-w-sm flex-col px-6 py-24">
    <h1 class="text-2xl font-semibold">Welcome back</h1>
    <p class="mt-1.5 text-sm muted">Log in to access your dashboard.</p>
    <form class="mt-7 space-y-2.5" onsubmit="event.preventDefault()">
      <input type="email" placeholder="Email" required class="w-full rounded-lg border bg-white px-3.5 py-2.5 text-sm outline-none focus:border-[color:var(--color-accent)]" />
      <input type="password" placeholder="Password" required class="w-full rounded-lg border bg-white px-3.5 py-2.5 text-sm outline-none focus:border-[color:var(--color-accent)]" />
      <button class="btn btn-accent w-full">Log in</button>
    </form>
    <p class="mt-5 text-center text-sm muted">No account? <a href="/signup" class="text-[color:var(--color-accent)]">Sign up</a></p>
  </section>
</Base>
