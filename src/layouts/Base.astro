---
import "../styles/global.css";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import RevealScript from "../components/RevealScript.astro";
import LoadMoreScript from "../components/LoadMoreScript.astro";
const { title = "Exclusive Mentorship", description = "Institutional-grade trading mentorship by NLT. 99 scripted classes across 7 chapters." } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen antialiased">
    <Nav />
    <main><slot /></main>
    <Footer />
    <RevealScript />
    <LoadMoreScript />
  </body>
</html>
