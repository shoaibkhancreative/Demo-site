---
const { id, eyebrow, title, subtitle, align = "center", width = "wide", class: cls = "" } = Astro.props;
const maxw = width === "narrow" ? "max-w-3xl" : width === "mid" ? "max-w-4xl" : "max-w-5xl";
const alignCls = align === "center" ? "text-center" : "text-left";
---
<section id={id} class={`mx-auto ${maxw} px-6 py-16 ${cls}`}>
  {(eyebrow || title || subtitle) && (
    <div class={`reveal mb-10 ${alignCls}`}>
      {eyebrow && <p class="eyebrow">{eyebrow}</p>}
      {title && <h2 class="mt-2 text-3xl font-semibold sm:text-4xl">{title}</h2>}
      {subtitle && <p class={`mt-3 text-sm muted ${align === "center" ? "mx-auto max-w-md" : "max-w-md"}`}>{subtitle}</p>}
    </div>
  )}
  <slot />
</section>
