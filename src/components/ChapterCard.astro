---
import Thumb from "./Thumb.astro";
import { CHAPTER_BUNDLE_PRICING } from "../data/site.js";
const { chapter, open = false } = Astro.props;
const unlockPrice = CHAPTER_BUNDLE_PRICING[chapter.id];
const joinLabel = chapter.id > 1 ? `Unlock 1–${chapter.id} · $${unlockPrice}` : `Join Chapter 1 · $${unlockPrice}`;
---
<article
  class:list={["reveal card chapter rounded-2xl bg-ink-2 p-5 sm:p-6", { open }]}
  data-chapter
  aria-expanded={open ? "true" : "false"}
>
  <!-- TOP: thumbnail left, title/info right -->
  <div class="flex flex-col gap-5 sm:flex-row sm:items-center sm:gap-7">
    <!-- Thumbnail (left) -->
    <div class="relative w-full shrink-0 sm:w-64 lg:w-72">
      <Thumb src={chapter.thumb} label={`Chapter ${chapter.id}`} />
      <span class="price-badge absolute right-3 top-3 backdrop-blur"><span class="text-xs opacity-70">$</span>{unlockPrice}</span>
    </div>

    <!-- Title / info (right, large) -->
    <div class="min-w-0 flex-1">
      <div class="flex items-center gap-3 text-xs uppercase tracking-widest text-neutral-500">
        <span class="display text-2xl normal-case tracking-normal text-gold/70">{String(chapter.id).padStart(2,'0')}</span>
        <span>Chapter {chapter.id}</span>
        <span class="text-neutral-700">·</span>
        <span>{chapter.classes} classes</span>
      </div>
      <h3 class="display mt-2 text-2xl leading-tight sm:text-3xl">{chapter.name}</h3>
      <p class="mt-2 max-w-2xl text-sm leading-relaxed text-neutral-400">{chapter.hook}</p>
      <div class="mt-4 flex items-center gap-4">
        <a href={`/checkout?chapter=${chapter.id}`} data-stop class="rounded-full bg-gold px-6 py-2 text-sm font-semibold text-black transition hover:bg-gold-soft">{joinLabel}</a>
        <a href={`/chapters/${chapter.id}`} data-stop class="text-sm font-medium text-neutral-300 transition hover:text-gold">Read more →</a>
        <span class="ml-auto chev hidden text-lg sm:block" aria-hidden="true">▾</span>
      </div>
    </div>
  </div>

  <!-- EXPAND: class list (title + tagline) under the title -->
  <div class="panel">
    <div class="panel-inner">
      <div class="rule mb-5"></div>
      <p class="mb-4 text-xs uppercase tracking-[0.25em] text-gold">What's inside</p>
      <ol class="space-y-1">
        {chapter.lessons.map((l) => (
          <li class="group flex items-baseline gap-4 rounded-lg px-3 py-2.5 transition hover:bg-ink-3">
            <span class="w-7 shrink-0 text-sm font-semibold text-gold/80">{String(l.n).padStart(2,'0')}</span>
            <div class="min-w-0">
              <p class="text-sm font-medium text-neutral-100">{l.title}</p>
              <p class="mt-0.5 text-xs leading-relaxed text-neutral-500">{l.tagline}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </div>
</article>
