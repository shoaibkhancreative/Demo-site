---
import Thumb from "./Thumb.astro";
const { chapter, open = false } = Astro.props;
---
<article
  class:list={["reveal card chapter rounded-2xl bg-ink-2 p-5", { open }]}
  data-chapter
  aria-expanded={open ? "true" : "false"}
>
  <div class="relative">
    <Thumb src={chapter.thumb} label={`Chapter ${chapter.id}`} />
    <span class="price-badge absolute right-3 top-3 backdrop-blur"><span class="text-xs opacity-70">$</span>{chapter.price}</span>
  </div>

  <div class="mt-5 flex items-start justify-between gap-3">
    <div>
      <div class="flex items-center gap-3 text-xs text-neutral-500">
        <span class="display text-xl text-gold/70">{String(chapter.id).padStart(2,'0')}</span>
        <span>{chapter.classes} classes</span>
      </div>
      <h3 class="display mt-1.5 text-xl">{chapter.name}</h3>
    </div>
    <span class="chev mt-1 shrink-0 text-lg" aria-hidden="true">▾</span>
  </div>
  <p class="mt-2 text-sm leading-relaxed text-neutral-400">{chapter.hook}</p>

  <!-- Expandable panel: full class list -->
  <div class="panel">
    <div>
      <ol class="divide-y divide-line border-t border-line">
        {chapter.lessons.map((l) => (
          <li class="flex items-baseline gap-3 py-2.5">
            <span class="w-6 shrink-0 text-xs font-semibold text-gold">{String(l.n).padStart(2,'0')}</span>
            <div class="min-w-0">
              <p class="text-sm font-medium text-neutral-200">{l.title}</p>
              <p class="text-xs text-neutral-500">{l.tagline}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </div>

  <div class="mt-5 flex items-center gap-3">
    <a href="/signup" data-stop class="flex-1 rounded-full bg-gold py-2.5 text-center text-sm font-semibold text-black transition hover:bg-gold-soft">Join · ${chapter.price}</a>
    <a href={`/chapters/${chapter.id}`} data-stop class="rounded-full border border-line px-5 py-2.5 text-sm font-medium text-neutral-300 transition hover:border-gold hover:text-gold">Read more →</a>
  </div>
</article>
