---
import Thumb from "./Thumb.astro";
const { chapter } = Astro.props;
const preview = chapter.lessons.slice(0, 3);
---
<article class="reveal card group flex flex-col rounded-2xl bg-ink-2 p-5">
  <div class="relative">
    <Thumb src={chapter.thumb} label={`Chapter ${chapter.id}`} />
    <span class="price-badge absolute right-3 top-3 backdrop-blur"><span class="text-xs opacity-70">$</span>{chapter.price}</span>
  </div>

  <div class="mt-5 flex items-center gap-3 text-xs text-neutral-500">
    <span class="display text-xl text-gold/70">{String(chapter.id).padStart(2,'0')}</span>
    <span>{chapter.classes} classes</span>
  </div>
  <h3 class="display mt-1.5 text-xl">{chapter.name}</h3>
  <p class="mt-2 text-sm leading-relaxed text-neutral-400">{chapter.hook}</p>

  <details class="acc mt-4 rounded-xl border border-line bg-ink px-4 py-3">
    <summary class="flex items-center justify-between text-sm font-medium text-neutral-300">
      <span>Preview first 3 classes</span>
      <span class="chev text-gold">▾</span>
    </summary>
    <ul class="mt-3 space-y-2 border-t border-line pt-3">
      {preview.map((l) => (
        <li class="flex gap-2 text-sm">
          <span class="text-xs font-semibold text-gold">{String(l.n).padStart(2,'0')}</span>
          <span class="text-neutral-300">{l.title}</span>
        </li>
      ))}
    </ul>
  </details>

  <div class="mt-5 flex items-center gap-3">
    <a href="/signup" class="flex-1 rounded-full bg-gold py-2.5 text-center text-sm font-semibold text-black transition hover:bg-gold-soft">Join · ${chapter.price}</a>
    <a href={`/chapters/${chapter.id}`} class="rounded-full border border-line px-5 py-2.5 text-sm font-medium text-neutral-300 transition hover:border-gold hover:text-gold">Read more →</a>
  </div>
</article>
