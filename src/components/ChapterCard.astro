---
import Thumb from "./Thumb.astro";
const { chapter } = Astro.props;
const preview = chapter.lessons.slice(0, 3);
const rest = chapter.lessons.slice(3);
---
<article class="reveal group rounded-2xl border border-line bg-ink-2 p-5 transition duration-300 hover:border-gold/50 hover:shadow-[0_0_40px_-12px_rgba(212,175,55,.35)]">
  <Thumb src={chapter.thumb} label={`Chapter ${chapter.id}`} />

  <div class="mt-5 flex items-center justify-between">
    <span class="text-xs font-medium text-gold">Chapter {chapter.id}</span>
    <span class="text-xs text-neutral-500">{chapter.classes} classes · ${chapter.price}</span>
  </div>
  <h3 class="mt-2 text-lg font-semibold">{chapter.name}</h3>
  <p class="mt-2 text-sm text-neutral-400">{chapter.hook}</p>

  <ul class="mt-5 space-y-3 border-t border-line pt-4" id={`ch-${chapter.id}-preview`}>
    {preview.map((l) => (
      <li class="flex gap-3">
        <span class="mt-0.5 text-xs font-semibold text-gold">{String(l.n).padStart(2,'0')}</span>
        <div>
          <p class="text-sm font-medium text-neutral-200">{l.title}</p>
          <p class="text-xs text-neutral-500">{l.tagline}</p>
        </div>
      </li>
    ))}
  </ul>

  {rest.length > 0 && (
    <>
      <ul class="mt-3 space-y-3 hidden" id={`ch-${chapter.id}-rest`}>
        {rest.map((l) => (
          <li class="flex gap-3">
            <span class="mt-0.5 text-xs font-semibold text-gold">{String(l.n).padStart(2,'0')}</span>
            <div>
              <p class="text-sm font-medium text-neutral-200">{l.title}</p>
              <p class="text-xs text-neutral-500">{l.tagline}</p>
            </div>
          </li>
        ))}
      </ul>
      <button
        class="mt-5 w-full rounded-full border border-line py-2 text-sm font-medium text-neutral-300 transition hover:border-gold hover:text-gold"
        data-loadmore={chapter.id}
      >
        Load more ({rest.length})
      </button>
    </>
  )}
</article>
