---
// The site's signature visual: an actual liquidity-sweep-and-reversal pattern,
// marked up exactly the way the mentorship teaches students to mark up their
// own charts (SSL swept -> reclaimed through an Order Block -> Break of
// Structure -> runs to resting BSL). Not a decorative gradient — this is the
// literal subject matter of chapters 2-3 of the curriculum.
//
// variant="hero"  -> full annotated, staggered draw-in animation (use once)
// variant="quiet" -> candles only, low opacity, static (safe to reuse as ambient texture)
interface Props {
  variant?: "hero" | "quiet";
  class?: string;
}
const { variant = "hero", class: klass = "" } = Astro.props;
---

<svg viewBox="0 0 980 480" class={`chart-art ${klass}`} preserveAspectRatio="xMidYMid meet" role="img" aria-label="একটি liquidity sweep এবং reversal দেখানো একটি annotated price chart">
  <g class="candles">
    <g class="candle" style="animation-delay:0ms"><line x1="42.0" y1="351.1" x2="42.0" y2="379.4" stroke="var(--color-up)" stroke-width="2" stroke-linecap="round"/><rect x="26.0" y="358.2" width="32.0" height="7.1" rx="1.3" fill="var(--color-up)"/></g>
    <g class="candle" style="animation-delay:40ms"><line x1="80.9" y1="344.0" x2="80.9" y2="372.3" stroke="var(--color-down)" stroke-width="2" stroke-linecap="round"/><rect x="65.0" y="358.2" width="32.0" height="7.1" rx="1.3" fill="var(--color-down)"/></g>
    <g class="candle" style="animation-delay:80ms"><line x1="119.9" y1="358.2" x2="119.9" y2="386.5" stroke="var(--color-down)" stroke-width="2" stroke-linecap="round"/><rect x="103.9" y="365.3" width="32.0" height="7.1" rx="1.3" fill="var(--color-down)"/></g>
    <g class="candle" style="animation-delay:120ms"><line x1="158.9" y1="358.2" x2="158.9" y2="379.4" stroke="var(--color-up)" stroke-width="2" stroke-linecap="round"/><rect x="142.9" y="365.3" width="32.0" height="7.1" rx="1.3" fill="var(--color-up)"/></g>
    <g class="candle" style="animation-delay:160ms"><line x1="197.8" y1="351.1" x2="197.8" y2="386.5" stroke="var(--color-down)" stroke-width="2" stroke-linecap="round"/><rect x="181.8" y="365.3" width="32.0" height="14.1" rx="1.3" fill="var(--color-down)"/></g>
    <g class="candle" style="animation-delay:200ms"><line x1="236.8" y1="365.3" x2="236.8" y2="400.6" stroke="var(--color-up)" stroke-width="2" stroke-linecap="round"/><rect x="220.8" y="372.3" width="32.0" height="7.1" rx="1.3" fill="var(--color-up)"/></g>
    <g class="candle" style="animation-delay:240ms"><line x1="275.7" y1="358.2" x2="275.7" y2="386.5" stroke="var(--color-up)" stroke-width="2" stroke-linecap="round"/><rect x="259.8" y="365.3" width="32.0" height="7.1" rx="1.3" fill="var(--color-up)"/></g>
    <g class="candle" style="animation-delay:280ms"><line x1="314.7" y1="351.1" x2="314.7" y2="379.4" stroke="var(--color-up)" stroke-width="2" stroke-linecap="round"/><rect x="298.7" y="358.2" width="32.0" height="7.1" rx="1.3" fill="var(--color-up)"/></g>
    <g class="candle" style="animation-delay:320ms"><line x1="353.6" y1="351.1" x2="353.6" y2="379.4" stroke="var(--color-down)" stroke-width="2" stroke-linecap="round"/><rect x="337.7" y="358.2" width="32.0" height="14.1" rx="1.3" fill="var(--color-down)"/></g>
    <g class="candle" style="animation-delay:360ms"><line x1="392.6" y1="365.3" x2="392.6" y2="393.6" stroke="var(--color-down)" stroke-width="2" stroke-linecap="round"/><rect x="376.6" y="372.3" width="32.0" height="14.1" rx="1.3" fill="var(--color-down)"/></g>
    <g class="candle" style="animation-delay:400ms"><line x1="431.6" y1="379.4" x2="431.6" y2="436.0" stroke="var(--color-down)" stroke-width="2" stroke-linecap="round"/><rect x="415.6" y="386.5" width="32.0" height="42.4" rx="1.3" fill="var(--color-down)" stroke="var(--color-gold)" stroke-width="1.4"/></g>
    <g class="candle" style="animation-delay:440ms"><line x1="470.5" y1="329.9" x2="470.5" y2="436.0" stroke="var(--color-up)" stroke-width="2" stroke-linecap="round"/><rect x="454.5" y="337.0" width="32.0" height="92.0" rx="1.3" fill="var(--color-up)"/></g>
    <g class="candle" style="animation-delay:480ms"><line x1="509.5" y1="273.3" x2="509.5" y2="344.0" stroke="var(--color-up)" stroke-width="2" stroke-linecap="round"/><rect x="493.5" y="287.4" width="32.0" height="49.5" rx="1.3" fill="var(--color-up)"/></g>
    <g class="candle" style="animation-delay:520ms"><line x1="548.4" y1="266.2" x2="548.4" y2="308.7" stroke="var(--color-down)" stroke-width="2" stroke-linecap="round"/><rect x="532.5" y="287.4" width="32.0" height="14.1" rx="1.3" fill="var(--color-down)"/></g>
    <g class="candle" style="animation-delay:560ms"><line x1="587.4" y1="223.8" x2="587.4" y2="308.7" stroke="var(--color-up)" stroke-width="2" stroke-linecap="round"/><rect x="571.4" y="230.9" width="32.0" height="70.7" rx="1.3" fill="var(--color-up)"/></g>
    <g class="candle" style="animation-delay:600ms"><line x1="626.4" y1="209.6" x2="626.4" y2="252.1" stroke="var(--color-up)" stroke-width="2" stroke-linecap="round"/><rect x="610.4" y="216.7" width="32.0" height="14.1" rx="1.3" fill="var(--color-up)"/></g>
    <g class="candle" style="animation-delay:640ms"><line x1="665.3" y1="202.6" x2="665.3" y2="237.9" stroke="var(--color-down)" stroke-width="2" stroke-linecap="round"/><rect x="649.3" y="216.7" width="32.0" height="14.1" rx="1.3" fill="var(--color-down)"/></g>
    <g class="candle" style="animation-delay:680ms"><line x1="704.3" y1="167.2" x2="704.3" y2="237.9" stroke="var(--color-up)" stroke-width="2" stroke-linecap="round"/><rect x="688.3" y="174.3" width="32.0" height="56.6" rx="1.3" fill="var(--color-up)"/></g>
    <g class="candle" style="animation-delay:720ms"><line x1="743.2" y1="160.1" x2="743.2" y2="195.5" stroke="var(--color-down)" stroke-width="2" stroke-linecap="round"/><rect x="727.2" y="174.3" width="32.0" height="14.1" rx="1.3" fill="var(--color-down)"/></g>
    <g class="candle" style="animation-delay:760ms"><line x1="782.2" y1="117.7" x2="782.2" y2="195.5" stroke="var(--color-up)" stroke-width="2" stroke-linecap="round"/><rect x="766.2" y="124.7" width="32.0" height="63.7" rx="1.3" fill="var(--color-up)"/></g>
    <g class="candle" style="animation-delay:800ms"><line x1="821.1" y1="103.5" x2="821.1" y2="138.9" stroke="var(--color-up)" stroke-width="2" stroke-linecap="round"/><rect x="805.2" y="110.6" width="32.0" height="14.1" rx="1.3" fill="var(--color-up)"/></g>
    <g class="candle" style="animation-delay:840ms"><line x1="860.1" y1="96.4" x2="860.1" y2="131.8" stroke="var(--color-down)" stroke-width="2" stroke-linecap="round"/><rect x="844.1" y="110.6" width="32.0" height="14.1" rx="1.3" fill="var(--color-down)"/></g>
    <g class="candle" style="animation-delay:880ms"><line x1="899.1" y1="61.1" x2="899.1" y2="131.8" stroke="var(--color-up)" stroke-width="2" stroke-linecap="round"/><rect x="883.1" y="68.1" width="32.0" height="56.6" rx="1.3" fill="var(--color-up)"/></g>
    <g class="candle" style="animation-delay:920ms"><line x1="938.0" y1="54.0" x2="938.0" y2="82.3" stroke="var(--color-up)" stroke-width="2" stroke-linecap="round"/><rect x="922.0" y="61.1" width="32.0" height="7.1" rx="1.3" fill="var(--color-up)"/></g>
  </g>

  {variant === "hero" && (
    <g class="annotations" font-family="var(--font-mono)">
      <!-- SSL: prior swing low, swept -->
      <g class="ann" style="animation-delay:1020ms">
        <line x1="26" y1="400.6" x2="463" y2="400.6" stroke="var(--color-gold)" stroke-width="1.1" stroke-dasharray="2 5" opacity="0.85"/>
        <circle cx="431.6" cy="400.6" r="5.5" fill="none" stroke="var(--color-gold)" stroke-width="1.4"/>
        <text x="30" y="393" fill="var(--color-gold)" font-size="15" letter-spacing="2">SSL</text>
      </g>

      <!-- Order Block: last down candle before displacement, projected forward -->
      <g class="ann" style="animation-delay:1260ms">
        <rect x="415.6" y="386.5" width="564.4" height="42.4" fill="var(--color-gold)" opacity="0.09"/>
        <line x1="415.6" y1="386.5" x2="980" y2="386.5" stroke="var(--color-gold)" stroke-width="1" stroke-dasharray="3 4" opacity="0.55"/>
        <line x1="415.6" y1="428.9" x2="980" y2="428.9" stroke="var(--color-gold)" stroke-width="1" stroke-dasharray="3 4" opacity="0.55"/>
        <text x="470" y="378" fill="var(--color-gold)" font-size="14" letter-spacing="2">ORDER BLOCK</text>
      </g>

      <!-- BOS: range high, broken -->
      <g class="ann" style="animation-delay:1500ms">
        <line x1="26" y1="344" x2="475" y2="344" stroke="var(--color-gold)" stroke-width="1.1" stroke-dasharray="2 5" opacity="0.85"/>
        <text x="30" y="336" fill="var(--color-gold)" font-size="15" letter-spacing="2">BOS</text>
      </g>

      <!-- BSL: resting liquidity target -->
      <g class="ann" style="animation-delay:1740ms">
        <line x1="700" y1="57.1" x2="980" y2="57.1" stroke="var(--color-gold)" stroke-width="1.1" stroke-dasharray="2 5" opacity="0.85"/>
        <text x="705" y="49" fill="var(--color-gold)" font-size="15" letter-spacing="2">BSL</text>
      </g>
    </g>
  )}
</svg>

<style define:vars={{ quietOpacity: variant === "quiet" ? "0.16" : "1" }}>
  .chart-art { width: 100%; height: 100%; display: block; opacity: var(--quietOpacity); }
  .candle { animation: rise .55s cubic-bezier(.16,1,.3,1) both; }
  .ann { animation: rise .7s cubic-bezier(.16,1,.3,1) both; }
  @keyframes rise { from { opacity: 0; transform: translateY(7px); } to { opacity: 1; transform: translateY(0); } }
  @media (prefers-reduced-motion: reduce) {
    .candle, .ann { animation: none; opacity: 1; transform: none; }
  }
</style>
