---
/**
 * HeroTape — the site's one signature illustration. Hand-authored (not random):
 * a gentle rise, a sweep below the prior low, then a sharp reversal to new highs.
 * To a casual visitor it just reads as "a market going up with character." To a
 * student three chapters in, it's literally the pattern this course teaches.
 */
const W = 1200;
const H = 280;

const points: [number, number][] = [
  [0, 190], [90, 176], [180, 196], [280, 150], [370, 169],
  [460, 224], [512, 163], [600, 96], [700, 120], [800, 60],
  [900, 80], [1000, 40], [1100, 54], [1200, 45],
];

function smoothPath(p: [number, number][]) {
  let d = `M ${p[0][0]} ${p[0][1]}`;
  for (let i = 1; i < p.length - 1; i++) {
    const mx = (p[i][0] + p[i + 1][0]) / 2;
    const my = (p[i][1] + p[i + 1][1]) / 2;
    d += ` Q ${p[i][0]} ${p[i][1]}, ${mx.toFixed(1)} ${my.toFixed(1)}`;
  }
  const last = p[p.length - 1];
  d += ` L ${last[0]} ${last[1]}`;
  return d;
}
const linePath = smoothPath(points);
const areaPath = `${linePath} L ${W} ${H} L 0 ${H} Z`;

const sweep = points[5];
const high = points[11];

const wickCount = 30;
const wicks = Array.from({ length: wickCount }, (_, i) => {
  const x = (W / (wickCount - 1)) * i;
  const h = 12 + 9 * Math.abs(Math.sin(i * 1.7)) + 5 * Math.abs(Math.sin(i * 0.53));
  const yMid = 150 + 46 * Math.sin(i * 0.31 + 0.6) - i * 0.75;
  const up = Math.sin(i * 0.9) > -0.15;
  return { x, y1: yMid - h / 2, y2: yMid + h / 2, up };
});
---

<svg viewBox={`0 0 ${W} ${H}`} class="hero-tape" preserveAspectRatio="none" aria-hidden="true">
  <defs>
    <linearGradient id="heroTapeFill" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="var(--color-accent)" stop-opacity="0.22" />
      <stop offset="100%" stop-color="var(--color-accent)" stop-opacity="0" />
    </linearGradient>
    <linearGradient id="heroTapeMask" x1="0" y1="0" x2="1" y2="0">
      <stop offset="0%" stop-color="#fff" stop-opacity="0" />
      <stop offset="8%" stop-color="#fff" stop-opacity="1" />
      <stop offset="92%" stop-color="#fff" stop-opacity="1" />
      <stop offset="100%" stop-color="#fff" stop-opacity="0" />
    </linearGradient>
    <mask id="heroTapeEdgeFade">
      <rect x="0" y="0" width={W} height={H} fill="url(#heroTapeMask)" />
    </mask>
  </defs>

  <g mask="url(#heroTapeEdgeFade)">
    {wicks.map((w) => (
      <line
        x1={w.x.toFixed(1)} x2={w.x.toFixed(1)} y1={w.y1.toFixed(1)} y2={w.y2.toFixed(1)}
        stroke={w.up ? "var(--color-market-up)" : "var(--color-market-down)"}
        stroke-width="2.4" stroke-linecap="round" opacity="0.16"
      />
    ))}
    <path d={areaPath} fill="url(#heroTapeFill)" stroke="none" />
    <path
      d={linePath} fill="none" stroke="var(--color-accent)" stroke-width="2.6"
      stroke-linecap="round" stroke-linejoin="round" pathLength="1" class="hero-tape-line"
    />
    <circle cx={sweep[0]} cy={sweep[1]} r="4" fill="var(--color-market-down)" class="hero-tape-dot" style="--dot-delay:1.5s" />
    <circle cx={high[0]} cy={high[1]} r="4" fill="var(--color-accent)" class="hero-tape-dot" style="--dot-delay:1.9s" />
  </g>
</svg>
