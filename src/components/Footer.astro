---
import { BRAND, TELEGRAM, TOTAL_CLASSES, PRICING } from "../data/site.js";
const year = new Date().getFullYear();
---
<footer class="border-t">
  <!-- CTA band -->
  <div class="bg-[color:var(--color-ink)]">
    <div class="mx-auto max-w-5xl px-6 py-14 text-center">
      <p class="eyebrow !text-white/50">Ready when you are</p>
      <h2 class="mt-2 text-2xl font-semibold text-white sm:text-3xl">Start with Chapter 1 today.</h2>
      <p class="mx-auto mt-2 max-w-md text-[13px] leading-relaxed text-white/55">{TOTAL_CLASSES} scripted classes across 7 chapters, delivered privately on Telegram.</p>
      <div class="mt-6 flex flex-wrap items-center justify-center gap-3">
        <a href="/checkout" class="btn btn-accent">Get access · ${PRICING.tier2Bundle}</a>
        <a href={TELEGRAM} class="btn border border-white/15 text-white transition hover:bg-white/10">Message us on Telegram</a>
      </div>
    </div>
  </div>

  <!-- Links -->
  <div class="bg-[color:var(--color-surface)]">
    <div class="mx-auto max-w-5xl px-6 py-14">
      <div class="grid gap-10 sm:grid-cols-2 md:grid-cols-4">
        <!-- Brand -->
        <div class="sm:col-span-2">
          <div class="flex items-center gap-2 text-sm font-semibold"><span class="grid h-6 w-6 place-items-center rounded-md bg-[color:var(--color-ink)] text-[11px] text-white">EM</span> {BRAND}</div>
          <p class="mt-3 max-w-xs text-[13px] leading-relaxed muted">Institutional-grade trading mentorship by NLT. {TOTAL_CLASSES} scripted classes across 7 chapters, delivered privately on Telegram.</p>
          <div class="mt-4 flex items-center gap-4 text-[11px] faint">
            <span class="chip !py-0.5 !px-2">₿ BTC</span><span class="chip !py-0.5 !px-2">₮ USDT</span><span class="chip !py-0.5 !px-2">Ξ ETH</span>
          </div>
        </div>

        <!-- Learn -->
        <div class="text-[13px]">
          <p class="mb-3 font-medium">Learn</p>
          <ul class="space-y-2 muted">
            <li><a href="/#curriculum" class="transition hover:text-[color:var(--color-ink)]">Curriculum</a></li>
            <li><a href="/#instructor" class="transition hover:text-[color:var(--color-ink)]">Instructor</a></li>
            <li><a href="/#intro" class="transition hover:text-[color:var(--color-ink)]">Introduction</a></li>
          </ul>
        </div>

        <!-- Buy -->
        <div class="text-[13px]">
          <p class="mb-3 font-medium">Buy</p>
          <ul class="space-y-2 muted">
            <li><a href="/#pricing" class="transition hover:text-[color:var(--color-ink)]">Pricing</a></li>
            <li><a href="/checkout" class="transition hover:text-[color:var(--color-ink)]">Get access</a></li>
            <li><a href="/checkout" class="transition hover:text-[color:var(--color-ink)]">Add-ons</a></li>
            <li><a href={TELEGRAM} class="text-[color:var(--color-accent)] transition hover:opacity-80">Telegram support</a></li>
          </ul>
        </div>
      </div>

      <div class="my-9 rule"></div>

      <div class="flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
        <p class="max-w-2xl text-[11px] leading-relaxed faint"><span class="font-medium text-[color:var(--color-muted)]">Risk Disclaimer.</span> Trading involves substantial risk of loss and is not suitable for every investor. All content is educational only and is not financial advice. Past performance does not guarantee future results.</p>
        <div class="flex shrink-0 gap-4 text-[11px] faint">
          <a href="/privacy" class="transition hover:text-[color:var(--color-ink)]">Privacy</a>
          <a href="/terms" class="transition hover:text-[color:var(--color-ink)]">Terms</a>
          <a href="/refund" class="transition hover:text-[color:var(--color-ink)]">Refund</a>
          <span>© {year} {BRAND}</span>
        </div>
      </div>
    </div>
  </div>
</footer>
