---
import { BRAND, TELEGRAM, TOTAL_CLASSES, PRICING } from "../data/site.js";
const year = new Date().getFullYear();
---
<footer class="mt-24 border-t border-[color:var(--color-line)]">
  <!-- CTA band -->
  <div class="band-navy">
    <div class="wrap mx-auto max-w-5xl px-6 py-16 text-center sm:py-20">
      <p class="eyebrow justify-center !text-[color:var(--color-gold-bright)]">আপনি প্রস্তুত হলেই</p>
      <h2 class="mt-3 text-[1.9rem] font-semibold leading-[1.15] sm:text-4xl">আজই শুরু করুন, চ্যাপ্টার ০১ থেকে।</h2>
      <p class="muted-on-navy mx-auto mt-3 max-w-md text-[13.5px] leading-relaxed">৭টি চ্যাপ্টার জুড়ে {TOTAL_CLASSES}টি scripted ক্লাস — Telegram-এ সরাসরি, ব্যক্তিগতভাবে পৌঁছে দেওয়া হয়।</p>
      <div class="mt-7 flex flex-wrap items-center justify-center gap-3">
        <a href="/checkout" class="btn btn-gold">সম্পূর্ণ অ্যাক্সেস নিন · ${PRICING.tier2Bundle}</a>
        <a href={TELEGRAM} class="btn btn-on-navy">Telegram-এ মেসেজ করুন</a>
      </div>
    </div>
  </div>

  <!-- Links -->
  <div class="bg-[color:var(--color-paper)]">
    <div class="wrap mx-auto max-w-5xl px-6 py-14">
      <div class="grid gap-10 sm:grid-cols-2 md:grid-cols-4">
        <div class="sm:col-span-2">
          <div class="flex items-center gap-2.5 text-[15px] font-semibold">
            <span class="nav-mark">EM</span>
            <span class="font-display">{BRAND}</span>
          </div>
          <p class="mt-3.5 max-w-xs text-[13px] leading-relaxed muted">NLT-এর institutional-grade ট্রেডিং মেন্টরশিপ। ৭টি চ্যাপ্টার জুড়ে {TOTAL_CLASSES}টি scripted ক্লাস, Telegram-এ ব্যক্তিগতভাবে পৌঁছে দেওয়া হয়।</p>
          <div class="mt-5 flex items-center gap-2 text-[11px] faint">
            <span class="chip !py-1">₿ BTC</span><span class="chip !py-1">₮ USDT</span><span class="chip !py-1">Ξ ETH</span>
          </div>
        </div>

        <div class="text-[13px] footer-links">
          <p class="mb-3 font-semibold">শিখুন</p>
          <ul class="space-y-2.5 muted">
            <li><a href="/#curriculum" class="hover:text-[color:var(--color-gold-deep)]">কারিকুলাম</a></li>
            <li><a href="/#instructor" class="hover:text-[color:var(--color-gold-deep)]">মেন্টর</a></li>
            <li><a href="/#intro" class="hover:text-[color:var(--color-gold-deep)]">পরিচিতি ভিডিও</a></li>
          </ul>
        </div>

        <div class="text-[13px] footer-links">
          <p class="mb-3 font-semibold">কিনুন</p>
          <ul class="space-y-2.5 muted">
            <li><a href="/#pricing" class="hover:text-[color:var(--color-gold-deep)]">মূল্য</a></li>
            <li><a href="/checkout" class="hover:text-[color:var(--color-gold-deep)]">অ্যাক্সেস নিন</a></li>
            <li><a href="/checkout" class="hover:text-[color:var(--color-gold-deep)]">অ্যাড-অন</a></li>
            <li><a href={TELEGRAM} class="font-medium text-[color:var(--color-gold-deep)]">Telegram সাপোর্ট</a></li>
          </ul>
        </div>
      </div>

      <div class="my-10 rule"></div>

      <div class="flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
        <p class="max-w-2xl text-[11px] leading-relaxed faint"><span class="font-medium text-[color:var(--color-ink-soft)]">রিস্ক ডিসক্লেইমার।</span> ট্রেডিং-এ উল্লেখযোগ্য ক্ষতির ঝুঁকি থাকে এবং এটি প্রত্যেক বিনিয়োগকারীর জন্য উপযুক্ত নয়। এখানকার সব কনটেন্ট শুধুমাত্র শিক্ষামূলক উদ্দেশ্যে তৈরি, এটি কোনো আর্থিক পরামর্শ নয়। অতীতের ফলাফল ভবিষ্যতের ফলাফলের নিশ্চয়তা দেয় না।</p>
        <div class="flex shrink-0 gap-4 text-[11px] faint footer-links">
          <a href="/privacy" class="hover:text-[color:var(--color-ink)]">গোপনীয়তা</a>
          <a href="/terms" class="hover:text-[color:var(--color-ink)]">শর্তাবলী</a>
          <a href="/refund" class="hover:text-[color:var(--color-ink)]">রিফান্ড</a>
          <span>© {year} {BRAND}</span>
        </div>
      </div>
    </div>
  </div>
</footer>
