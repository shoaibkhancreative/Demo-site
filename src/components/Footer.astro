---
import { BRAND, TELEGRAM, TOTAL_CLASSES, PRICING } from "../data/site.js";
const year = new Date().getFullYear();
---
<footer class="mt-28 border-t bg-[color:var(--color-surface)]">
  <!-- CTA band -->
  <div class="border-b">
    <div class="mx-auto flex max-w-5xl flex-col items-center justify-between gap-5 px-6 py-12 text-center sm:flex-row sm:text-left">
      <div>
        <h3 class="text-2xl font-semibold">Ready to trade like the institutions?</h3>
        <p class="mt-1.5 text-sm muted">Get all {TOTAL_CLASSES} scripted classes for ${PRICING.tier2Bundle}. 7-day money-back guarantee.</p>
      </div>
      <div class="flex shrink-0 gap-2.5">
        <a href="/checkout" class="btn btn-accent">Get full access</a>
        <a href={TELEGRAM} class="btn btn-ghost">Talk to us</a>
      </div>
    </div>
  </div>

  <!-- links -->
  <div class="mx-auto max-w-5xl px-6 py-12">
    <div class="grid gap-10 sm:grid-cols-2 md:grid-cols-4">
      <div class="sm:col-span-2 md:col-span-1">
        <div class="flex items-center gap-2 text-sm font-semibold"><span class="grid h-6 w-6 place-items-center rounded-md bg-[color:var(--color-ink)] text-[11px] text-white">EM</span> {BRAND}</div>
        <p class="mt-3 max-w-xs text-[13px] leading-relaxed muted">Institutional-grade trading mentorship by NLT. Scripted, structured, built for serious traders.</p>
      </div>
      <div class="text-[13px]">
        <p class="mb-3 font-medium">Product</p>
        <ul class="space-y-2 muted">
          <li><a href="/#curriculum" class="transition hover:text-[color:var(--color-ink)]">Curriculum</a></li>
          <li><a href="/#pricing" class="transition hover:text-[color:var(--color-ink)]">Pricing</a></li>
          <li><a href="/checkout" class="transition hover:text-[color:var(--color-ink)]">Get access</a></li>
          <li><a href="/login" class="transition hover:text-[color:var(--color-ink)]">Log in</a></li>
        </ul>
      </div>
      <div class="text-[13px]">
        <p class="mb-3 font-medium">Legal</p>
        <ul class="space-y-2 muted">
          <li><a href="/privacy" class="transition hover:text-[color:var(--color-ink)]">Privacy Policy</a></li>
          <li><a href="/terms" class="transition hover:text-[color:var(--color-ink)]">Terms of Service</a></li>
          <li><a href="/refund" class="transition hover:text-[color:var(--color-ink)]">Refund Policy</a></li>
        </ul>
      </div>
      <div class="text-[13px]">
        <p class="mb-3 font-medium">Support</p>
        <a href={TELEGRAM} class="inline-flex items-center gap-1.5 text-[color:var(--color-accent)] transition hover:opacity-80">Telegram →</a>
        <div class="mt-4 flex gap-1.5">
          <span class="chip !py-0.5 !px-2">₿ BTC</span><span class="chip !py-0.5 !px-2">₮ USDT</span><span class="chip !py-0.5 !px-2">Ξ ETH</span>
        </div>
      </div>
    </div>

    <div class="my-9 rule"></div>
    <div class="flex flex-col gap-4 text-[11px] leading-relaxed faint md:flex-row md:items-start md:justify-between">
      <p class="max-w-2xl"><span class="font-medium text-[color:var(--color-muted)]">Risk Disclaimer.</span> Trading involves substantial risk of loss and is not suitable for every investor. All content is educational only and is not financial advice. Past performance does not guarantee future results.</p>
      <p class="shrink-0">© {year} {BRAND}</p>
    </div>
  </div>
</footer>
