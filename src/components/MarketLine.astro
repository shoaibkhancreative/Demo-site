---
/**
 * MarketLine — a small deterministic "price session" line, seeded per-id so the
 * same chapter always renders the same shape (no hydration/rebuild flicker).
 * This is the site's signature motif: every chapter card, thumbnail and modal
 * carries a quiet fragment of "chart" behind its content instead of a stock photo.
 */
interface Props {
  seed: number;
  width?: number;
  height?: number;
  points?: number;
  area?: boolean;
  strokeWidth?: number;
  trend?: number;
  class?: string;
}
const {
  seed,
  width = 400,
  height = 120,
  points = 9,
  area = false,
  strokeWidth = 2,
  trend = 0.4,
  class: className = "",
} = Astro.props;

function mulberry32(a: number) {
  return function () {
    a |= 0;
    a = (a + 0x6d2b79f5) | 0;
    let t = Math.imul(a ^ (a >>> 15), 1 | a);
    t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
    return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
  };
}

const rand = mulberry32(seed * 9301 + 49297);
const padY = height * 0.18;
const top = padY;
const bottom = height - padY;
const span = bottom - top;

let y = bottom - span * (0.2 + rand() * 0.25);
const pts: [number, number][] = [];
for (let i = 0; i < points; i++) {
  const x = (width / (points - 1)) * i;
  const drift = (rand() - 0.5 - trend * 0.5) * span * 0.36;
  y = Math.min(bottom, Math.max(top, y + drift));
  pts.push([x, y]);
}

function smoothPath(p: [number, number][]) {
  if (p.length < 2) return "";
  let d = `M ${p[0][0].toFixed(1)} ${p[0][1].toFixed(1)}`;
  for (let i = 1; i < p.length - 1; i++) {
    const mx = (p[i][0] + p[i + 1][0]) / 2;
    const my = (p[i][1] + p[i + 1][1]) / 2;
    d += ` Q ${p[i][0].toFixed(1)} ${p[i][1].toFixed(1)}, ${mx.toFixed(1)} ${my.toFixed(1)}`;
  }
  const last = p[p.length - 1];
  d += ` L ${last[0].toFixed(1)} ${last[1].toFixed(1)}`;
  return d;
}

const linePath = smoothPath(pts);
const areaPath = `${linePath} L ${width} ${height} L 0 ${height} Z`;
const gradId = `mg-${seed}-${Math.round(width)}-${Math.round(height)}`;
---

<svg viewBox={`0 0 ${width} ${height}`} class={className} preserveAspectRatio="none" aria-hidden="true">
  {area && (
    <defs>
      <linearGradient id={gradId} x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="var(--color-accent)" stop-opacity="0.24" />
        <stop offset="100%" stop-color="var(--color-accent)" stop-opacity="0" />
      </linearGradient>
    </defs>
  )}
  {area && <path d={areaPath} fill={`url(#${gradId})`} stroke="none" />}
  <path
    d={linePath}
    fill="none"
    stroke="var(--color-accent)"
    stroke-width={strokeWidth}
    stroke-linecap="round"
    stroke-linejoin="round"
  />
</svg>
