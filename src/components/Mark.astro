  <circle cx="16" cy="16" r="15" fill="var(--color-surface)" stroke="var(--color-line-2)" stroke-width="1"/>
  <circle cx="16" cy="16" r="12.25" fill="none" stroke="var(--color-accent)" stroke-width=".7" opacity=".55"/>
  <text x="16" y="19.6" text-anchor="middle" font-family="Newsreader, 'Noto Serif Bengali', Georgia, serif" font-size="11.5" font-weight="600" fill="var(--color-accent)">EM</text>
</svg>
