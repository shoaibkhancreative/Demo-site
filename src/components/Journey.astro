---
import { CHAPTERS } from "../data/site.js";
---
<div>
  <!-- compact grid: all 7 chapters visible at once -->
  <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
    {CHAPTERS.map((c) => (
      <button type="button" class="ch-tile group" data-open={c.id}>
        <div class="flex items-center justify-between">
          <span class="grid h-8 w-8 place-items-center rounded-lg bg-[color:var(--color-bg)] text-xs font-semibold text-[color:var(--color-accent)]">{String(c.id).padStart(2,'0')}</span>
          <span class="chip">${c.price}</span>
        </div>
        <h3 class="mt-3 text-[15px] font-semibold leading-snug">{c.name}</h3>
        <p class="mt-1.5 line-clamp-2 text-[13px] leading-relaxed muted">{c.hook}</p>
        <div class="mt-3 flex items-center justify-between text-[12px]">
          <span class="faint">{c.classes} classes</span>
          <span class="font-medium text-[color:var(--color-accent)]">View lessons →</span>
        </div>
      </button>
    ))}
  </div>

  <!-- modals -->
  {CHAPTERS.map((c) => (
    <div class="modal" data-modal={c.id}>
      <div class="modal-backdrop" data-close></div>
      <div class="modal-panel">
        <div class="flex items-start justify-between gap-4 border-b p-5">
          <div>
            <p class="text-xs font-medium faint">Chapter {c.id} · {c.classes} classes · ${c.price}</p>
            <h3 class="mt-1 text-lg font-semibold">{c.name}</h3>
          </div>
          <button type="button" data-close class="grid h-8 w-8 place-items-center rounded-lg border text-muted transition hover:bg-[color:var(--color-bg)]">✕</button>
        </div>
        <div class="max-h-[52vh] overflow-auto p-5">
          <ol class="space-y-2.5">
            {c.lessons.map((l) => (
              <li class="flex items-baseline gap-3">
                <span class="w-6 shrink-0 text-xs font-semibold text-[color:var(--color-accent)]">{String(l.n).padStart(2,'0')}</span>
                <div><p class="text-[14px] font-medium leading-snug">{l.title}</p><p class="text-[12px] muted">{l.tagline}</p></div>
              </li>
            ))}
          </ol>
        </div>
        <div class="flex items-center gap-3 border-t p-5">
          <a href={`/chapters/${c.id}`} class="btn btn-accent flex-1">Join this chapter · ${c.price}</a>
          <a href="/checkout" class="btn btn-ghost">Full bundle</a>
        </div>
      </div>
    </div>
  ))}
</div>

<script is:inline>
  (function(){
    const bind = () => {
      const openBtns = document.querySelectorAll('[data-open]');
      const close = () => document.querySelectorAll('.modal.open').forEach(m => m.classList.remove('open'));
      openBtns.forEach(b => {
        if (b.dataset.bound) return; b.dataset.bound="1";
        b.addEventListener('click', () => {
          const id = b.getAttribute('data-open');
          close();
          const m = document.querySelector('[data-modal="'+id+'"]');
          if (m) m.classList.add('open');
        });
      });
      document.querySelectorAll('[data-close]').forEach(x => {
        if (x.dataset.bound) return; x.dataset.bound="1";
        x.addEventListener('click', close);
      });
      document.addEventListener('keydown', (e)=>{ if(e.key==='Escape') close(); });
    };
    document.addEventListener('DOMContentLoaded', bind);
    document.addEventListener('astro:page-load', bind);
  })();
</script>
