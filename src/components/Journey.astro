---
import Thumb from "./Thumb.astro";
const { chapters } = Astro.props;
---
<div class="space-y-6" data-curriculum>
  {chapters.map((c) => {
    const preview = c.lessons.slice(0, 3);
    const rest = c.lessons.slice(3);
    return (
      <div class="chapter surface hoverable group p-6 sm:p-9">
        <span class="chapter-index">{String(c.id).padStart(2,'0')}</span>
        <div class="rel grid gap-8 md:grid-cols-[minmax(0,320px)_1fr] md:items-start">
          <div>
            <div class="relative">
              <Thumb src={c.thumb} label={`Chapter ${c.id}`} />
              <span class="price-badge absolute right-4 top-4"><span class="text-xs opacity-70">$</span>{c.price}</span>
            </div>
            <a href={`/chapters/${c.id}`} class="btn btn-primary mt-4 w-full">Join this chapter · ${c.price}</a>
          </div>

          <div class="min-w-0">
            <p class="eyebrow">Chapter {c.id} · {c.classes} classes</p>
            <h3 class="display mt-2.5 text-2xl sm:text-[2rem]">{c.name}</h3>
            <p class="mt-3 max-w-xl text-[15px] leading-relaxed muted">{c.hook}</p>

            <ul class="mt-7 space-y-3.5">
              {preview.map((l) => (
                <li class="flex items-baseline gap-3">
                  <span class="lesson-dot"></span>
                  <span class="text-[15px]"><span class="font-medium">{l.title}</span><span class="muted"> — {l.tagline}</span></span>
                </li>
              ))}
              <div class="lessons-extra space-y-3.5" data-extra>
                {rest.map((l) => (
                  <li class="flex items-baseline gap-3">
                    <span class="lesson-dot"></span>
                    <span class="text-[15px]"><span class="font-medium">{l.title}</span><span class="muted"> — {l.tagline}</span></span>
                  </li>
                ))}
              </div>
            </ul>

            {rest.length > 0 && (
              <button type="button" data-toggle data-count={c.classes} class="mt-6 text-sm font-semibold text-[color:var(--color-gold)] transition hover:opacity-75">
                Show all {c.classes} classes ↓
              </button>
            )}
          </div>
        </div>
      </div>
    );
  })}
</div>
