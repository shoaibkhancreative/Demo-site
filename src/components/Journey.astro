---
import { CHAPTERS } from "../data/site.js";
const ROMAN = ["", "I", "II", "III", "IV", "V", "VI", "VII", "VIII", "IX", "X"];
---
<div>
  <!-- table-of-contents style row list -->
  <div class="border-t border-b border-[color:var(--color-line-2)]">
    {CHAPTERS.map((c) => (
      <button type="button" class="toc-row group" data-open={c.id}>
        <span class="toc-numeral">{ROMAN[c.id]}</span>
        <span class="min-w-0 flex-1">
          <span class="flex flex-wrap items-baseline gap-x-2.5 gap-y-0.5">
            <span class="font-[family-name:var(--font-serif)] text-[17px] font-medium leading-snug sm:text-[19px]">{c.name}</span>
            <span class="font-mono text-[11px] faint">{c.classes}টি ক্লাস</span>
          </span>
          <span class="mt-1 line-clamp-1 block text-[13px] leading-relaxed muted">{c.hook}</span>
        </span>
        <span class="hidden shrink-0 font-mono text-[15px] text-[color:var(--color-accent)] sm:block">${c.price}</span>
        <svg class="toc-arrow" width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M6.5 3.5L11 8L6.5 12.5" stroke="var(--color-accent)" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    ))}
  </div>

  <!-- modals -->
  {CHAPTERS.map((c) => (
    <div class="modal" data-modal={c.id}>
      <div class="modal-backdrop" data-close></div>
      <div class="modal-panel">
        <div class="flex items-start justify-between gap-4 border-b p-5">
          <div>
            <p class="font-mono text-[11px] font-medium faint">চ্যাপ্টার {ROMAN[c.id]} · {c.classes}টি ক্লাস · ${c.price}</p>
            <h3 class="mt-1 font-[family-name:var(--font-serif)] text-lg font-medium">{c.name}</h3>
          </div>
          <button type="button" data-close class="grid h-8 w-8 shrink-0 place-items-center rounded-lg border text-muted transition hover:border-[color:var(--color-accent)] hover:text-[color:var(--color-accent)]">✕</button>
        </div>
        <div class="max-h-[52vh] overflow-auto p-5">
          <ol class="space-y-3.5">
            {c.lessons.map((l) => (
              <li class="flex items-baseline gap-3.5">
                <span class="w-6 shrink-0 font-mono text-[11px] font-medium text-[color:var(--color-accent)]">{String(l.n).padStart(2,'0')}</span>
                <div><p class="text-[14px] font-medium leading-snug">{l.title}</p><p class="mt-0.5 text-[12px] muted">{l.tagline}</p></div>
              </li>
            ))}
          </ol>
        </div>
        <div class="flex items-center gap-3 border-t p-5">
          <a href={`/chapters/${c.id}`} class="btn btn-accent flex-1">এই চ্যাপ্টার নিন · ${c.price}</a>
          <a href="/checkout" class="btn btn-ghost">ফুল বান্ডেল</a>
        </div>
      </div>
    </div>
  ))}
</div>

<script is:inline>
  (function(){
    const bind = () => {
      const openBtns = document.querySelectorAll('[data-open]');
      const close = () => document.querySelectorAll('.modal.open').forEach(m => m.classList.remove('open'));
      openBtns.forEach(b => {
        if (b.dataset.bound) return; b.dataset.bound="1";
        b.addEventListener('click', () => {
          const id = b.getAttribute('data-open');
          close();
          const m = document.querySelector('[data-modal="'+id+'"]');
          if (m) m.classList.add('open');
        });
      });
      document.querySelectorAll('[data-close]').forEach(x => {
        if (x.dataset.bound) return; x.dataset.bound="1";
        x.addEventListener('click', close);
      });
      document.addEventListener('keydown', (e)=>{ if(e.key==='Escape') close(); });
    };
    document.addEventListener('DOMContentLoaded', bind);
    document.addEventListener('astro:page-load', bind);
  })();
</script>
