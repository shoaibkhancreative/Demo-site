---
import { CHAPTERS } from "../data/site.js";
import Thumb from "./Thumb.astro";
---
<div>
  <!-- compact grid: all 7 chapters visible at once -->
  <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    {CHAPTERS.map((c) => (
      <button type="button" class="ch-tile group text-left" data-open={c.id}>
        <Thumb src={c.thumb} label={`চ্যাপ্টার ${c.id}`} id={c.id} />
        <div class="mt-4 flex items-center justify-between">
          <span class="eyebrow">চ্যাপ্টার {String(c.id).padStart(2,'0')}</span>
          <span class="chip-gold chip">${c.price}</span>
        </div>
        <h3 class="mt-2 text-[16px] leading-snug text-ivory">{c.name}</h3>
        <p class="mt-1.5 line-clamp-2 text-[13px] leading-relaxed muted">{c.hook}</p>
        <div class="mt-3.5 flex items-center justify-between text-[12px]">
          <span class="faint font-mono">{c.classes}টি ক্লাস</span>
          <span class="font-medium text-gold">লেসন দেখুন →</span>
        </div>
      </button>
    ))}
  </div>

  <!-- modals -->
  {CHAPTERS.map((c) => (
    <div class="modal" data-modal={c.id}>
      <div class="modal-backdrop" data-close></div>
      <div class="modal-panel">
        <div class="flex items-start justify-between gap-4 border-b border-ink-4 p-5">
          <div>
            <p class="eyebrow">চ্যাপ্টার {String(c.id).padStart(2,'0')} · {c.classes}টি ক্লাস · ${c.price}</p>
            <h3 class="mt-2 text-xl text-ivory">{c.name}</h3>
          </div>
          <button type="button" data-close class="grid h-8 w-8 shrink-0 place-items-center rounded-lg border border-ink-4 text-sand transition hover:border-gold-dim hover:text-gold">✕</button>
        </div>
        <div class="max-h-[52vh] overflow-auto p-5">
          <ol class="space-y-3">
            {c.lessons.map((l) => (
              <li class="flex items-baseline gap-3">
                <span class="w-7 shrink-0 font-mono text-xs font-semibold text-gold">{String(l.n).padStart(2,'0')}</span>
                <div><p class="text-[14px] font-medium leading-snug text-ivory">{l.title}</p><p class="text-[12px] muted">{l.tagline}</p></div>
              </li>
            ))}
          </ol>
        </div>
        <div class="flex items-center gap-3 border-t border-ink-4 p-5">
          <a href={`/chapters/${c.id}`} class="btn btn-accent flex-1">এই চ্যাপ্টার নিন · ${c.price}</a>
          <a href="/checkout" class="btn btn-ghost">ফুল বান্ডেল</a>
        </div>
      </div>
    </div>
  ))}
</div>

<script is:inline>
  (function(){
    const bind = () => {
      const openBtns = document.querySelectorAll('[data-open]');
      const close = () => document.querySelectorAll('.modal.open').forEach(m => m.classList.remove('open'));
      openBtns.forEach(b => {
        if (b.dataset.bound) return; b.dataset.bound="1";
        b.addEventListener('click', () => {
          const id = b.getAttribute('data-open');
          close();
          const m = document.querySelector('[data-modal="'+id+'"]');
          if (m) m.classList.add('open');
        });
      });
      document.querySelectorAll('[data-close]').forEach(x => {
        if (x.dataset.bound) return; x.dataset.bound="1";
        x.addEventListener('click', close);
      });
      document.addEventListener('keydown', (e)=>{ if(e.key==='Escape') close(); });
    };
    document.addEventListener('DOMContentLoaded', bind);
    document.addEventListener('astro:page-load', bind);
  })();
</script>
