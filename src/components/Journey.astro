---
import Thumb from "./Thumb.astro";
const { chapters } = Astro.props;
---
<div class="space-y-6">
  {chapters.map((c) => (
    <a href={`/chapters/${c.id}`} class="chapter-row card group block rounded-3xl bg-ink-2 p-6 sm:p-8">
      <div class="grid gap-7 md:grid-cols-[minmax(0,340px)_1fr] md:items-center">

        <!-- Left: number + thumbnail -->
        <div class="relative">
          <span class="chapter-index display">{String(c.id).padStart(2,'0')}</span>
          <div class="relative">
            <Thumb src={c.thumb} label={`Chapter ${c.id}`} />
            <span class="price-badge absolute right-4 top-4"><span class="text-xs opacity-70">$</span>{c.price}</span>
          </div>
        </div>

        <!-- Right: title, hook, first 3 classes, CTA -->
        <div class="min-w-0">
          <p class="text-xs uppercase tracking-[0.3em] text-neutral-500">Chapter {c.id} · {c.classes} classes</p>
          <h3 class="display mt-2 text-2xl leading-tight transition group-hover:text-gold-soft sm:text-3xl">{c.name}</h3>
          <p class="mt-3 max-w-xl text-sm leading-relaxed text-neutral-400">{c.hook}</p>

          <ul class="mt-6 space-y-2.5">
            {c.lessons.slice(0, 3).map((l) => (
              <li class="flex items-baseline gap-3">
                <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-gold/70"></span>
                <span class="text-sm text-neutral-300">{l.title}<span class="text-neutral-600"> — {l.tagline}</span></span>
              </li>
            ))}
          </ul>

          <div class="mt-7 flex items-center gap-5">
            <span class="rounded-full bg-gold px-6 py-2.5 text-sm font-semibold text-black transition group-hover:bg-gold-soft">Join · ${c.price}</span>
            <span class="text-sm font-medium text-neutral-400 transition group-hover:text-gold">View all {c.classes} classes →</span>
          </div>
        </div>
      </div>
    </a>
  ))}
</div>
