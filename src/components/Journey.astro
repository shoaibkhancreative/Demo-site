---
import { CHAPTERS, CHAPTER_BUNDLE_PRICING, PRICING } from "../data/site.js";
---
<div>
  <!-- ascending staircase: each chapter steps in further than the last, exactly the order they unlock in -->
  <div class="stair">
    {CHAPTERS.map((c) => (
      <button type="button" class="stair-item reveal" style={`--lift:${(c.id - 1) * 16}px`} data-open={c.id}>
        <span class="stair-num">{String(c.id).padStart(2,'0')}</span>
        <span class="min-w-0">
          <span class="block truncate text-[15px] font-semibold sm:text-base">{c.name}</span>
          <span class="mt-0.5 hidden text-[12.5px] leading-snug muted sm:line-clamp-1 sm:block">{c.hook}</span>
          <span class="mt-1 block text-[11.5px] faint">{c.classes}টি ক্লাস</span>
        </span>
        <span class="stair-price">${c.price}</span>
        <svg class="stair-arrow" width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M6 3.5L12.5 9L6 14.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
    ))}
  </div>

  <!-- modals: full lesson list per chapter -->
  {CHAPTERS.map((c) => (
    <div class="modal" data-modal={c.id}>
      <div class="modal-backdrop" data-close></div>
      <div class="modal-panel">
        <div class="flex items-start justify-between gap-4 border-b border-[color:var(--color-line)] p-5 sm:p-6">
          <div>
            <p class="eyebrow">চ্যাপ্টার {String(c.id).padStart(2,'0')} · {c.classes}টি ক্লাস · ${c.price}</p>
            <h3 class="mt-2 text-xl font-semibold leading-snug">{c.name}</h3>
            <p class="mt-1 text-[13px] leading-relaxed muted">{c.hook}</p>
          </div>
          <button type="button" data-close class="grid h-9 w-9 shrink-0 place-items-center rounded-lg border border-[color:var(--color-line)] text-[color:var(--color-ink-soft)] transition hover:border-[color:var(--color-gold)] hover:text-[color:var(--color-ink)]" aria-label="বন্ধ করুন">✕</button>
        </div>
        <div class="max-h-[48vh] overflow-auto p-5 sm:p-6">
          <ol class="space-y-3">
            {c.lessons.map((l) => (
              <li class="flex items-baseline gap-3">
                <span class="lesson-num">{String(l.n).padStart(2,'0')}</span>
                <div>
                  <p class="text-[14px] font-medium leading-snug">{l.title}</p>
                  <p class="mt-0.5 text-[12.5px] italic muted">{l.tagline}</p>
                </div>
              </li>
            ))}
          </ol>
        </div>
        <div class="flex items-center gap-3 border-t border-[color:var(--color-line)] p-5 sm:p-6">
          <a href={`/checkout?chapter=${c.id}`} class="btn btn-gold flex-1">এই চ্যাপ্টার নিন · ${CHAPTER_BUNDLE_PRICING[c.id]}</a>
          <a href="/checkout" class="btn btn-ghost">ফুল বান্ডেল · ${PRICING.tier2Bundle}</a>
        </div>
      </div>
    </div>
  ))}
</div>

<script is:inline>
  (function(){
    const bind = () => {
      const openBtns = document.querySelectorAll('[data-open]');
      const close = () => document.querySelectorAll('.modal.open').forEach(m => m.classList.remove('open'));
      openBtns.forEach(b => {
        if (b.dataset.bound) return; b.dataset.bound = "1";
        b.addEventListener('click', () => {
          const id = b.getAttribute('data-open');
          close();
          const m = document.querySelector('[data-modal="'+id+'"]');
          if (m) m.classList.add('open');
        });
      });
      document.querySelectorAll('[data-close]').forEach(x => {
        if (x.dataset.bound) return; x.dataset.bound = "1";
        x.addEventListener('click', close);
      });
      document.addEventListener('keydown', (e) => { if (e.key === 'Escape') close(); });
    };
    document.addEventListener('DOMContentLoaded', bind);
    document.addEventListener('astro:page-load', bind);
  })();
</script>
