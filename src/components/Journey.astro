---
import Thumb from "./Thumb.astro";
const { chapters } = Astro.props;
---
<div class="space-y-6" data-curriculum>
  {chapters.map((c) => {
    const preview = c.lessons.slice(0, 3);
    const rest = c.lessons.slice(3);
    return (
      <div class="chapter-card card group rounded-3xl p-6 sm:p-8">
        <span class="chapter-index display">{String(c.id).padStart(2,'0')}</span>
        <div class="rel grid gap-7 md:grid-cols-[minmax(0,340px)_1fr] md:items-start">

          <!-- Left: thumbnail -->
          <div class="relative">
            <Thumb src={c.thumb} label={`Chapter ${c.id}`} />
            <span class="price-badge absolute right-4 top-4"><span class="text-xs opacity-70">$</span>{c.price}</span>
            <a href={`/chapters/${c.id}`} class="mt-4 block rounded-full bg-gold py-3 text-center text-sm font-semibold text-white transition hover:brightness-110">Join this chapter · ${c.price}</a>
          </div>

          <!-- Right: title, hook, all classes -->
          <div class="min-w-0">
            <p class="text-xs uppercase tracking-[0.3em] text-[color:var(--color-muted)]">Chapter {c.id} · {c.classes} classes</p>
            <h3 class="display mt-2 text-2xl leading-tight sm:text-3xl">{c.name}</h3>
            <p class="mt-3 max-w-xl text-sm leading-relaxed text-[color:var(--color-muted)]">{c.hook}</p>

            <ul class="mt-6 space-y-3">
              {preview.map((l) => (
                <li class="flex items-baseline gap-3">
                  <span class="lesson-dot"></span>
                  <span class="text-sm text-[color:var(--color-text)]">{l.title}<span class="text-[color:var(--color-muted)]"> — {l.tagline}</span></span>
                </li>
              ))}
              {rest.length > 0 && (
                <div class="lessons-extra space-y-3" data-extra>
                  {rest.map((l) => (
                    <li class="flex items-baseline gap-3">
                      <span class="lesson-dot"></span>
                      <span class="text-sm text-[color:var(--color-text)]">{l.title}<span class="text-[color:var(--color-muted)]"> — {l.tagline}</span></span>
                    </li>
                  ))}
                </div>
              )}
            </ul>

            {rest.length > 0 && (
              <button type="button" data-toggle class="mt-5 text-sm font-semibold text-gold transition hover:brightness-110">
                Show all {c.classes} classes ↓
              </button>
            )}
          </div>
        </div>
      </div>
    );
  })}
</div>
