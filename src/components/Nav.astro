---
import { BRAND } from "../data/site.js";
---
<header class="sticky top-0 z-50 border-b bg-[color:var(--color-bg)]/85 backdrop-blur-xl">
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-5">
    <a href="/" class="flex items-center gap-2 text-[15px] font-medium">
      <span class="text-[color:var(--color-gold)]">◆</span><span class="display">{BRAND}</span>
    </a>
    <div class="hidden items-center gap-9 text-[13px] muted md:flex">
      <a href="/#curriculum" class="transition hover:text-[color:var(--color-ink)]">Curriculum</a>
      <a href="/pricing" class="transition hover:text-[color:var(--color-ink)]">Pricing</a>
      <a href="/#instructor" class="transition hover:text-[color:var(--color-ink)]">Instructor</a>
      <a href="/login" class="transition hover:text-[color:var(--color-ink)]">Login</a>
    </div>
    <a href="/pricing" class="btn btn-primary !px-5 !py-2 !text-[13px]">Get Access</a>
  </nav>
</header>
