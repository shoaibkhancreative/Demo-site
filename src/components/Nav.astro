---
import { BRAND } from "../data/site.js";
---
<header class="sticky top-0 z-50 border-b border-line/50 bg-ink/70 backdrop-blur-xl">
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-5">
    <a href="/" class="flex items-center gap-2.5 text-[15px] font-medium tracking-tight">
      <span class="text-gold">◆</span><span class="display">{BRAND}</span>
    </a>
    <div class="hidden items-center gap-9 text-[13px] text-neutral-400 md:flex">
      <a href="/#curriculum" class="hover:text-white transition">Curriculum</a>
      <a href="/pricing" class="hover:text-white transition">Pricing</a>
      <a href="/#instructor" class="hover:text-white transition">Instructor</a>
      <a href="/login" class="hover:text-white transition">Login</a>
    </div>
    <a href="/pricing" class="rounded-full bg-gold px-5 py-2 text-[13px] font-semibold text-black transition hover:bg-gold-soft">Get Access</a>
  </nav>
</header>
