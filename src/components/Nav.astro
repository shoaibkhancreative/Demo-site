---
import { BRAND } from "../data/site.js";
import Mark from "./Mark.astro";
---
<header class="sticky top-0 z-50 border-b bg-[color:var(--color-bg)]/85 backdrop-blur-xl">
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-3.5">
    <a href="/" class="flex items-center gap-2.5 text-[15px] font-semibold">
      <Mark size={30} />
      <span class="font-[family-name:var(--font-serif)]">{BRAND}</span>
    </a>
    <div class="hidden items-center gap-8 text-[13px] muted md:flex">
      <a href="/#curriculum" class="transition hover:text-[color:var(--color-accent)]">কারিকুলাম</a>
      <a href="/#pricing" class="transition hover:text-[color:var(--color-accent)]">মূল্য</a>
      <a href="/#instructor" class="transition hover:text-[color:var(--color-accent)]">মেন্টর</a>
    </div>
    <div class="flex items-center gap-2">
      <a href="/checkout" class="btn btn-accent btn-sm">অ্যাক্সেস নিন</a>
    </div>
  </nav>
</header>
