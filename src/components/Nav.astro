---
import { BRAND } from "../data/site.js";
---
<header class="sticky top-0 z-50 border-b border-[color:var(--color-line)] bg-white/80 backdrop-blur-xl">
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-5">
    <a href="/" class="flex items-center gap-2.5 text-[15px] font-medium tracking-tight">
      <span class="text-gold">◆</span><span class="display">{BRAND}</span>
    </a>
    <div class="hidden items-center gap-9 text-[13px] text-[color:var(--color-muted)] md:flex">
      <a href="/#curriculum" class="transition hover:text-[color:var(--color-text)]">Curriculum</a>
      <a href="/pricing" class="transition hover:text-[color:var(--color-text)]">Pricing</a>
      <a href="/#instructor" class="transition hover:text-[color:var(--color-text)]">Instructor</a>
      <a href="/login" class="transition hover:text-[color:var(--color-text)]">Login</a>
    </div>
    <a href="/pricing" class="rounded-full bg-gold px-5 py-2 text-[13px] font-semibold text-white transition hover:brightness-110">Get Access</a>
  </nav>
</header>
