---
import { BRAND } from "../data/site.js";
---
<header class="sticky top-0 z-50 border-b border-ink-4 bg-ink/85 backdrop-blur-xl">
  <nav class="mx-auto flex max-w-5xl items-center justify-between px-6 py-3.5">
    <a href="/" class="flex items-center gap-2.5 text-[15px] font-semibold text-ivory">
      <span class="grid h-8 w-8 shrink-0 place-items-center rounded-lg border border-ink-4 bg-ink-2">
        <svg width="13" height="13" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <line x1="7" y1="0" x2="7" y2="14" stroke="var(--color-gold)" stroke-width="1.3"/>
          <rect x="4" y="4" width="6" height="6" rx="1" fill="var(--color-gold)"/>
        </svg>
      </span>
      <span class="font-display">{BRAND}</span>
    </a>
    <div class="hidden items-center gap-8 text-[13px] muted md:flex">
      <a href="/#curriculum" class="transition hover:text-ivory">কারিকুলাম</a>
      <a href="/#pricing" class="transition hover:text-ivory">মূল্য</a>
      <a href="/#instructor" class="transition hover:text-ivory">মেন্টর</a>
    </div>
    <div class="flex items-center gap-2">
      <a href="/checkout" class="btn btn-accent btn-sm">অ্যাক্সেস নিন</a>
    </div>
  </nav>
</header>
